                                            <Slider x:Name="InnerThicknessSlider" Style="{StaticResource MonoSlider}" Minimum="1" Maximum="30" Value="2" Margin="0,0,0,8" ValueChanged="CrosshairSlider_ValueChanged"/>
                                            
