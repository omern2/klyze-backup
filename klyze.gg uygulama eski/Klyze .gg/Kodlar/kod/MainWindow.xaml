<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ValorantAutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klyze" Height="800" Width="1200"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True" Icon="uygulama_logusu.png"
        ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
        ScrollViewer.CanContentScroll="False" UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#141414"/>
        <SolidColorBrush x:Key="CardBg" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="CardDark" Color="#252525"/>
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextGray" Color="#888888"/>
        <SolidColorBrush x:Key="AccentWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentLightGray" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BorderCol" Color="#2A2A2A"/>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#252525" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bd"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.97" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.97" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BigPrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.95" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.95" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.95" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.95" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardDark}"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#303030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MonoSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#FFFFFF" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" Background="White" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#3A3A3A" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="18" Height="18" Background="#252525" BorderBrush="#444" BorderThickness="1.5" CornerRadius="3" Margin="0,0,8,0">
                                <TextBlock x:Name="tick" Text="&#10003;" FontSize="11" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="White"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden"
                                        CanContentScroll="False"
                                        Margin="{TemplateBinding Padding}">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        
        <!-- Minimal ScrollBar Style -->
        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" 
                                                        Background="#3A3A3A" 
                                                        CornerRadius="3"
                                                        Margin="1,0,1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#555555"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#666666"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Padding="8">
        <Border Background="#0D0D0D" CornerRadius="12" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>
            <Grid x:Name="RootGrid" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarCol" Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- ÜST BAR — tüm genişlikte, her iki sütunu kaplıyor -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                        Background="#141414" BorderBrush="#222222" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown" Panel.ZIndex="10">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                            <Image Source="uygulama_logusu.png" Width="16" Height="16"
                                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,5,0"/>
                            <TextBlock Text="Klyze" FontSize="10" FontWeight="SemiBold" Foreground="#BBBBBB"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Width="32" Height="28" BorderThickness="0" Cursor="Hand" Click="MinimizeButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="wbd" Background="Transparent">
                                            <TextBlock Text="&#8722;" FontSize="14" Foreground="#555555"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="wbd" Property="Background" Value="#252525"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Width="32" Height="28" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="wbd2" Background="Transparent">
                                            <TextBlock Text="&#215;" FontSize="14" Foreground="#555555"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="wbd2" Property="Background" Value="#3A1A1A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBg}" x:Name="SidebarBorder"
                MouseEnter="Sidebar_MouseEnter" MouseLeave="Sidebar_MouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Nav Items -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Top nav -->
                    <StackPanel Grid.Row="0" Margin="0,16,0,0">
                        <!-- Ana Sayfa -->
                        <Button x:Name="MenuHome" Style="{StaticResource NavBtn}" Click="MenuHome_Click" Background="#252525" BorderBrush="{StaticResource AccentWhite}" BorderThickness="2,0,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                                <Image Source="Ana_sayfa.png" Width="26" Height="26" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock x:Name="LblHome" Text="Ana Sayfa" FontSize="12" Foreground="{StaticResource TextWhite}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>

                        <!-- Araçlar accordion -->
                        <!-- Araçlar butonu -->
                        <Button x:Name="MenuTools" Style="{StaticResource NavBtn}" Click="ToolsMenu_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                                <Image Source="oyun.png" Width="26" Height="26" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock x:Name="LblTools" Text="Araçlar" FontSize="12" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <!-- Alt menü — ClipToBounds ile smooth açılır -->
                        <Border x:Name="ToolsSubmenu" Height="0" ClipToBounds="True"
                                Background="#181818" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <Button x:Name="MenuAgent" Style="{StaticResource NavBtn}" Click="MenuAgent_Click" Height="44">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0">
                                        <Image Source="ajan_secimi.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.8"/>
                                        <TextBlock x:Name="LblAgent" Text="Ajan Seçimi" FontSize="11" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="MenuAfk" Style="{StaticResource NavBtn}" Click="MenuAfk_Click" Height="44">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0">
                                        <Image Source="afk_mode.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.8"/>
                                        <TextBlock x:Name="LblAfk" Text="AFK Mode" FontSize="11" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="MenuSpam" Style="{StaticResource NavBtn}" Click="MenuSpam_Click" Height="44">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0">
                                        <Image Source="yazi_spam.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.8"/>
                                        <TextBlock x:Name="LblSpam" Text="Yazı Spam" FontSize="11" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="MenuCrosshair" Style="{StaticResource NavBtn}" Click="MenuCrosshair_Click" Height="44">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0">
                                        <Image Source="crasair.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.8"/>
                                        <TextBlock x:Name="LblCrosshair" Text="Crosshair" FontSize="11" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="MenuPlayerAnalysis" Style="{StaticResource NavBtn}" Click="MenuPlayerAnalysis_Click" Height="44">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="24,0,0,0">
                                        <Image Source="agent.png" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Opacity="0.8"/>
                                        <TextBlock x:Name="LblPlayerAnalysis" Text="Oyuncu Analizi" FontSize="11" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Bottom nav -->
                    <StackPanel Grid.Row="1">
                        <Separator Background="{StaticResource BorderCol}" Margin="10,4"/>
                        <Button x:Name="MenuPlay" Style="{StaticResource NavBtn}" Click="MenuPlay_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                                <Border Width="26" Height="26" Background="Transparent">
                                    <TextBlock Text="🎮" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="LblPlay" Text="Oyna" FontSize="12" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="MenuAnaliz" Style="{StaticResource NavBtn}" Click="MenuAnaliz_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                                <Border Width="26" Height="26" Background="Transparent">
                                    <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="LblAnaliz" Text="Analiz" FontSize="12" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Separator Background="{StaticResource BorderCol}" Margin="10,4"/>
                        <Button x:Name="MenuSettings" Style="{StaticResource NavBtn}" Click="MenuSettings_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="16,0,0,0">
                                <Image Source="ayarlar.png" Width="26" Height="26" RenderOptions.BitmapScalingMode="HighQuality"/>
