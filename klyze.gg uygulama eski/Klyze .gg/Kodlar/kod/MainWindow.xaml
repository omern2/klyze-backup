                                                    <Button x:Name="ColorPurple" Width="24" Height="24" Background="#FF00FF" Margin="2" Click="CrosshairColor_Click" Tag="Purple" BorderThickness="0"/>
                                                    <Button x:Name="ColorWhite" Width="24" Height="24" Background="White" Margin="2" Click="CrosshairColor_Click" Tag="White" BorderThickness="0"/>
