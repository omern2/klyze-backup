                                            <Slider x:Name="OpacitySlider" Style="{StaticResource MonoSlider}" Minimum="10" Maximum="100" Value="100" ValueChanged="CrosshairSlider_ValueChanged"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

