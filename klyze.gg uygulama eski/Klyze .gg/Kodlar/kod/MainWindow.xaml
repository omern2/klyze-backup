                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Kalınlık" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="InnerThicknessValue" Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
