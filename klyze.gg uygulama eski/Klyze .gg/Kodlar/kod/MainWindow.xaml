                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="uygulama_logusu.png" Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="Klyze" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextWhite}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Border Background="#3A3A3A" CornerRadius="4" Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="v3.2.1" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Valorant ve Minecraft için gelişmiş otomasyon aracı." FontSize="13" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Ajan kilitleme, AFK modu ve yazı spam özellikleri ile oyun deneyiminizi geliştirin." FontSize="12" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1A1A" CornerRadius="10" Padding="24,20" BorderBrush="#3A3A3A" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Image Source="uyari.png" Width="22" Height="22" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="Sorumluluk Reddi" FontSize="14" FontWeight="Bold" Foreground="#888888" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextGray}" TextWrapping="Wrap" LineHeight="20">
                                    <Run Text="Bu yazılım yalnızca eğitim ve araştırma amaçlı geliştirilmiştir. Kullanım sırasında ortaya çıkabilecek her türlü sonuç (ban, hesap kısıtlaması, oyun ihlali vb.) tamamen kullanıcının sorumluluğundadır."/>
                                </TextBlock>
                                <TextBlock Text="Tüm sorumluluk oyuncuya aittir." FontSize="13" FontWeight="Bold" Foreground="#888888" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                            </StackPanel>
                    </Grid>

                        </Grid>
                    </ScrollViewer>
                </Border>
                
                <!-- External Scrollbar -->
                <ScrollBar Grid.Column="1" 
                         Style="{StaticResource MinimalScrollBar}"
                         Orientation="Vertical"
                         Margin="0,28,35,35"
                         Value="{Binding ElementName=MainScrollViewer, Path=VerticalOffset, Mode=OneWay}"
                         Maximum="{Binding ElementName=MainScrollViewer, Path=ScrollableHeight, Mode=OneWay}"
                         ViewportSize="{Binding ElementName=MainScrollViewer, Path=ViewportHeight, Mode=OneWay}"
                         Visibility="{Binding ElementName=MainScrollViewer, Path=ComputedVerticalScrollBarVisibility, Mode=OneWay}"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- GİRİŞ EKRANI OVERLAY — tüm uygulamanın üstünde, Grid.ColumnSpan=2 -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
              x:Name="LoginOverlay" Panel.ZIndex="200"
              Visibility="{Binding GirisEkraniGoster, Converter={StaticResource BoolToVis}}">
            <ContentControl x:Name="LoginPageControl"/>
        </Grid>

            </Grid>
        </Border>
    </Border>
</Window>


