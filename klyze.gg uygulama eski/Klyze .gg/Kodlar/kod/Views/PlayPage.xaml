<UserControl x:Class="ValorantAutoClicker.Views.PlayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:ValorantAutoClicker.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <h:InverseBoolConverter x:Key="InvBool"/>
        <h:StringToVisibilityConverter x:Key="StrToVis"/>
        <Style x:Key="BigActionBtn" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value></Setter>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.88"/></Trigger>
                        <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                            <BeginStoryboard><Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.96" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.96" Duration="0:0:0.08"/>
                            </Storyboard></BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                            <BeginStoryboard><Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                            </Storyboard></BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style x:Key="RankBadge" TargetType="Border">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" Margin="{TemplateBinding Padding}">
                            <ScrollViewer.Template><ControlTemplate TargetType="ScrollViewer"><ContentPresenter/></ControlTemplate></ScrollViewer.Template>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>
        <Style x:Key="RankBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#2A2A2A"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#555555"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.8"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#0D0D0D">
        <!-- SCREEN: MAIN -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScreenState}" Value="main">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel Margin="0,0,0,24">
                <Border Style="{StaticResource GlassCard}" Padding="24,18" Margin="0,0,0,20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Oyna" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="Mac bul veya lobi olustur" FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Style="{StaticResource RankBadge}" Margin="0,0,8,0">
                                <TextBlock Text="{Binding SeciliRutbe}" FontSize="11" FontWeight="Bold" Foreground="#AAAAAA"/>
                            </Border>
                            <Border Style="{StaticResource RankBadge}">
                                <TextBlock Text="{Binding OyuncuAdi}" FontSize="11" Foreground="#888888"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Oyuncu Adin" FontSize="12" Foreground="#888888" Margin="0,0,0,8"/>
                    <TextBox x:Name="OyuncuAdiBox" Style="{StaticResource DarkInput}"
                             Text="{Binding OyuncuAdi, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="MacBulButton"
                            Style="{StaticResource BigActionBtn}"
                            Background="#FFFFFF" Foreground="#0D0D0D"
                            Click="MacBulButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Mac Bul" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" x:Name="LobiOlusturButton"
                            Style="{StaticResource BigActionBtn}"
                            Background="#1E1E1E" Foreground="White"
                            BorderBrush="#3A3A3A" BorderThickness="1"
                            Click="LobiOlusturButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+ Lobi Olustur" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <Border Background="#1A0808" CornerRadius="8" Padding="14,10"
                        BorderBrush="#FF4655" BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FFAAAA" TextWrapping="Wrap"/>
                </Border>
                <Border Style="{StaticResource GlassCard}" Padding="14,10" Margin="0,12,0,0">
                    <TextBlock FontSize="11" Foreground="#555555" TextWrapping="Wrap">
                        <Run Text="Lobi olusturmak icin Valorant grup kodunu kullan. Mac bul ile rutbene uygun lobileri listele."/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- SCREEN: SEARCHING -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScreenState}" Value="searching">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Ellipse Width="72" Height="72" Stroke="#2A2A2A" StrokeThickness="5"/>
                    <Border Width="72" Height="72" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><RotateTransform x:Name="SpinnerRotate" Angle="0"/></Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1"/>
                                </Storyboard></BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Ellipse Width="72" Height="72" Stroke="White" StrokeThickness="5"
                                 StrokeDashArray="12 60"/>
                    </Border>
                </Grid>
                <TextBlock Text="Uygun lobiler araniyor..."
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SeciliRutbe, StringFormat='Rutbe: {0}'}"
                           FontSize="13" Foreground="#666666" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="3" Width="200"
                             Background="#252525" Foreground="White" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>

        <!-- SCREEN: RESULTS -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScreenState}" Value="results">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel Margin="0,0,0,24">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Lobiler" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#666666"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Geri"
                            Style="{StaticResource SmallBtn}"
                            Background="#1E1E1E" Foreground="#888888"
                            Padding="14,0" Command="{Binding GeriDonCommand}"/>
                </Grid>
                <Border Background="#1A0808" CornerRadius="8" Padding="14,10" Margin="0,0,0,12"
                        BorderBrush="#FF4655" BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FFAAAA" TextWrapping="Wrap"/>
                </Border>
                <!-- Bos durum -->
                <Border Padding="32,40" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LobiListesi.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Uygun lobi bulunamadi" FontSize="15" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Lobi olusturabilirsin!" FontSize="12" Foreground="#666666"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <Button Content="+ Lobi Olustur" Style="{StaticResource BigActionBtn}"
                                Background="#FFFFFF" Foreground="#0D0D0D" Width="200"
                                Command="{Binding LobiOlusturCommand}"/>
                    </StackPanel>
                </Border>
                <!-- Lobi kartlari -->
                <ItemsControl ItemsSource="{Binding LobiListesi}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#141414" CornerRadius="12" Padding="20,16"
                                    Margin="0,0,0,12" BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand">
                                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.MouseEnter">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-3" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#555555" Duration="0:0:0.15"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseLeave">
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#2A2A2A" Duration="0:0:0.15"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Ust: rutbe + oyuncu sayisi + katil butonu -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Style="{StaticResource RankBadge}" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Rutbe}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8,3">
                                                <TextBlock Text="{Binding OyuncuSayisiText}" FontSize="11" Foreground="#888888"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Katil" Height="30" Padding="16,0"
                                                Background="White" Foreground="#0D0D0D"
                                                FontSize="12" FontWeight="Bold"
                                                BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.LobiKatilCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <!-- Orta: lobi sahibi + grup kodu -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Olusturan}" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="  Grup Kodu: " FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding GrupKodu}" FontSize="11" FontWeight="Bold"
                                                   Foreground="#888888" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- Alt: 5 oyuncu slotu -->
                                    <ItemsControl Grid.Row="4" ItemsSource="{Binding Slotlar}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="56" Height="70" CornerRadius="10" Margin="0,0,8,0"
                                                        Background="#1A1A1A" BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Dolu}" Value="True"><Setter Property="BorderBrush" Value="#3A3A3A"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Dolu}" Value="False"><Setter Property="BorderBrush" Value="#252525"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <StackPanel Visibility="{Binding Dolu, Converter={StaticResource BoolToVis}}" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Oyuncu.Rutbe}" FontSize="7" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,3" TextTrimming="CharacterEllipsis"/>
                                                            <Ellipse Width="26" Height="26" Fill="#2A2A2A" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                            <TextBlock Text="{Binding Oyuncu.Ad}" FontSize="8" Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="2,0,2,2"/>
                                                            <TextBlock Text="{Binding Oyuncu.Ping, StringFormat={}{0}ms}" FontSize="7" Foreground="#555555" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <StackPanel Visibility="{Binding Dolu, Converter={StaticResource InvBoolToVis}}" VerticalAlignment="Center">
                                                            <TextBlock Text="+" FontSize="22" FontWeight="Light" Foreground="#333333" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- SCREEN: LOBBY -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ScreenState}" Value="lobby">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel Margin="0,0,0,24">
                <Border Style="{StaticResource GlassCard}" Padding="24,18" Margin="0,0,0,20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Aktif Lobi" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Content="Lobiden Ayril"
                                Style="{StaticResource SmallBtn}"
                                Background="#3A0A0A" Foreground="#FF6666"
                                Padding="16,0" Command="{Binding LobidenAyrilCommand}"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource GlassCard}" Padding="24,20" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource RankBadge}" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding AktifLobi.Rutbe}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <Border Background="#1A1A1A" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding AktifLobi.OyuncuSayisiText}" FontSize="12" Foreground="#888888"/>
                                </Border>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Text="{Binding AktifLobi.Olusturan}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                        </Grid>
                        <!-- Grup Kodu -->
                        <Border Background="#0D0D0D" CornerRadius="10" Padding="18,14" Margin="0,0,0,20"
                                BorderBrush="#3A3A3A" BorderThickness="1">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Grup Kodu" FontSize="11" Foreground="#666666" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding AktifLobi.GrupKodu}"
                                               FontSize="22" FontWeight="Bold" Foreground="White" FontFamily="Consolas"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Content="Kopyala"
                                        Style="{StaticResource SmallBtn}"
                                        Background="#252525" Foreground="#AAAAAA"
                                        Padding="12,0"
                                        Tag="{Binding AktifLobi.GrupKodu}"
                                        Click="KopyalaButton_Click"/>
                            </Grid>
                        </Border>
                        <!-- 5 Oyuncu Slotu -->
                        <TextBlock Text="Oyuncular" FontSize="13" FontWeight="SemiBold" Foreground="#888888" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding AktifLobi.Slotlar}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1" Columns="5"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="80" Height="100" CornerRadius="12" Margin="4,0"
                                            Background="#141414" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Dolu}" Value="True"><Setter Property="BorderBrush" Value="#3A3A3A"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Dolu}" Value="False"><Setter Property="BorderBrush" Value="#252525"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <StackPanel Visibility="{Binding Dolu, Converter={StaticResource BoolToVis}}"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Border Width="36" Height="36" CornerRadius="18" Background="#2A2A2A"
                                                        HorizontalAlignment="Center" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding Oyuncu.Ad}" FontSize="13" FontWeight="Bold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Oyuncu.Ad}" FontSize="9" Foreground="White"
                                                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                           MaxWidth="72" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding Oyuncu.Ping, StringFormat={}{0}ms}"
                                                           FontSize="8" Foreground="#555555" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Visibility="{Binding Dolu, Converter={StaticResource InvBoolToVis}}"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Border Width="36" Height="36" CornerRadius="18"
                                                        BorderBrush="#333333" BorderThickness="1.5"
                                                        HorizontalAlignment="Center" Margin="0,0,0,6">
                                                    <TextBlock Text="+" FontSize="20" FontWeight="Light" Foreground="#333333"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Bos" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Button Content="Lobiden Ayril"
                        Style="{StaticResource BigActionBtn}"
                        Background="#3A0A0A" Foreground="#FF6666"
                        BorderBrush="#FF4444" BorderThickness="1"
                        Command="{Binding LobidenAyrilCommand}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- MODAL: LOBI OLUSTUR -->
        <Grid Visibility="{Binding LobiModalAcik, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Rectangle Fill="#CC000000"/>
            <Border Background="#1A1A1A" BorderBrush="White" BorderThickness="1"
                    CornerRadius="16" Padding="32,28"
                    MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Lobi Olustur" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Valorant Grup Kodu" FontSize="12" Foreground="#888888" Margin="0,0,0,8"/>
                        <TextBox x:Name="JoinCodeBox" Style="{StaticResource DarkInput}"
                                 Text="{Binding GrupKoduInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="JoinCodeBox_KeyDown"/>
                        <TextBlock Text="Valorant oyununda Sosyal panelinden grup kodu olusturabilirsin."
                                   FontSize="10" Foreground="#555555" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="Rutbe" FontSize="12" Foreground="#888888" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding TumRutbeler}"
                                  SelectedItem="{Binding SeciliRutbe}"
                                  Background="#1A1A1A" Foreground="White"
                                  BorderBrush="#3A3A3A" BorderThickness="1"
                                  Height="40" FontSize="13">
                            <ComboBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A1A1A"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A2A2A"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            </ComboBox.Resources>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2A2A2A"/></Trigger>
                                        <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#333333"/></Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Iptal"
                                Style="{StaticResource BigActionBtn}"
                                Background="#252525" Foreground="#888888"
                                Command="{Binding ModalKapatCommand}"/>
                        <Button Grid.Column="2" Content="Olustur"
                                Style="{StaticResource BigActionBtn}"
                                Background="White" Foreground="#0D0D0D"
                                Command="{Binding LobiOlusturOnayCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- PANEL: RUTBE SECIM -->
        <Grid Visibility="{Binding RutbeSecimAcik, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Rectangle Fill="#CC000000"/>
            <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                    CornerRadius="16" Padding="32,28"
                    MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Rutbeni Sec" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,24"/>
                    <UniformGrid Rows="2" Columns="4" Margin="0,0,0,20">
                        <Button Content="Demir" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Demir"/>
                        <Button Content="Bronz" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Bronz"/>
                        <Button Content="Gumus" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Gümüş"/>
                        <Button Content="Altin" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Altın"/>
                        <Button Content="Platin" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Platin"/>
                        <Button Content="Elmas" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Elmas"/>
                        <Button Content="Olmsuz" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Ölümsüz"/>
                        <Button Content="Radyant" Style="{StaticResource RankBtn}" Margin="4" Command="{Binding RutbeSecCommand}" CommandParameter="Radyant"/>
                    </UniformGrid>
                    <Button Content="Iptal" Style="{StaticResource BigActionBtn}"
                            Background="#252525" Foreground="#888888"
                            Command="{Binding RutbeSecimKapatCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
