<UserControl x:Class="ValorantAutoClicker.Views.PlayerAnalysisPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:ValorantAutoClicker.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:WinColorConverter x:Key="WinColor"/>
        <h:KdColorConverter x:Key="KdColor"/>
        <h:WinRateColorConverter x:Key="WrColor"/>
        <h:StringToVisibilityConverter x:Key="StrToVis"/>
        <h:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </UserControl.Resources>
    <StackPanel VerticalAlignment="Top">

        <!-- Baslik -->
        <Border Background="#1E1E1E" CornerRadius="12" Padding="24,18" Margin="0,0,0,16"
                BorderBrush="#FF4655" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Oyuncu Analizi" FontSize="22" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Text="Tracker.gg ile Valorant istatistiklerini goruntule"
                               FontSize="13" Foreground="#888888"/>
                </StackPanel>
                <TextBlock Text="tracker.gg" FontSize="11" FontWeight="Bold"
                           Foreground="#FF4655" HorizontalAlignment="Right"
                           VerticalAlignment="Top" Opacity="0.7"/>
            </Grid>
        </Border>

        <!-- Arama Formu -->
        <Border Background="#1E1E1E" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Oyuncu Ara" FontSize="14" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Kullanici Adi -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kullanici Adi" FontSize="11" Foreground="#888888" Margin="0,0,0,6"/>
                        <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6">
                            <TextBox x:Name="GameNameBox"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,8" FontSize="13"
                                     CaretBrush="White"
                                     Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="SearchBox_KeyDown"/>
                        </Border>
                        <TextBlock Text="{Binding GameNameError}" FontSize="11"
                                   Foreground="#FF4655" Margin="2,4,0,0"
                                   Visibility="{Binding GameNameError, Converter={StaticResource StrToVis}}"/>
                    </StackPanel>

                    <!-- Etiket -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Etiket (#)" FontSize="11" Foreground="#888888" Margin="0,0,0,6"/>
                        <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6">
                            <TextBox x:Name="TagLineBox"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,8" FontSize="13"
                                     CaretBrush="White"
                                     Text="{Binding TagLine, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="SearchBox_KeyDown"/>
                        </Border>
                        <TextBlock Text="{Binding TagLineError}" FontSize="11"
                                   Foreground="#FF4655" Margin="2,4,0,0"
                                   Visibility="{Binding TagLineError, Converter={StaticResource StrToVis}}"/>
                    </StackPanel>

                    <!-- Ara Butonu -->
                    <Button Grid.Column="4" x:Name="SearchBtn"
                            Content="Ara" Height="38" Margin="0,18,0,0"
                            Background="#FF4655" Foreground="White"
                            FontSize="13" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="SearchBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Background" Value="#6B2C2C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Arama Gecmisi -->
                <ItemsControl ItemsSource="{Binding SearchHistory}"
                              Margin="0,12,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252525" CornerRadius="4" Padding="8,4" Margin="0,0,6,4"
                                    Cursor="Hand" MouseLeftButtonDown="HistoryItem_Click">
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#AAAAAA"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Yukleniyor -->
        <Border Background="#1E1E1E" CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Yukleniyor..." FontSize="14" Foreground="#888888"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar IsIndeterminate="True" Height="4" Width="200"
                             Background="#252525" Foreground="#FF4655"/>
            </StackPanel>
        </Border>

        <!-- Hata Mesaji -->
        <Border Background="#1A0808" CornerRadius="10" Padding="20,16"
                Margin="0,0,0,16" BorderBrush="#FF4655" BorderThickness="1"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Hata" FontSize="13" FontWeight="Bold"
                               Foreground="#FF4655" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                               Foreground="#CCCCCC" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Content="Tekrar Dene" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#FF4655" Foreground="White" FontSize="11" FontWeight="Bold"
                        BorderThickness="0" Padding="12,6" Cursor="Hand" Click="RetryBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Profil Verisi -->
        <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

            <!-- Profil Basligi -->
            <Border Background="#1E1E1E" CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    BorderBrush="#FF4655" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Profile.GameName}" FontSize="22" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="#" FontSize="18" Foreground="#888888" Margin="2,4,0,0"/>
                            <TextBlock Text="{Binding Profile.TagLine}" FontSize="18"
                                       Foreground="#888888" Margin="0,4,0,0"/>
                            <Border Background="#1A3A2A" CornerRadius="4" Padding="8,3" Margin="12,4,0,0"
                                    Visibility="{Binding FromCache, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Onbellekten" FontSize="10" FontWeight="Bold"
                                           Foreground="#00D26A"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Seviye " FontSize="12" Foreground="#888888"/>
                            <TextBlock Text="{Binding Profile.AccountLevel}" FontSize="12"
                                       FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Rank Bilgisi -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Profile.CurrentRankName}" FontSize="16"
                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Profile.CurrentRankRating}" FontSize="13"
                                       Foreground="#FF4655" FontWeight="Bold"/>
                            <TextBlock Text=" RR" FontSize="13" Foreground="#888888"/>
                        </StackPanel>
                        <TextBlock FontSize="11" Foreground="#888888" HorizontalAlignment="Right">
                            <Run Text="Peak: "/>
                            <Run Text="{Binding Profile.PeakRankName}" FontWeight="SemiBold" Foreground="#AAAAAA"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Istatistik Kartlari (4 lu grid) -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- K/D -->
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="K/D Orani" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Text="{Binding Profile.KdRatio, StringFormat={}{0:F2}}"
                                   Foreground="{Binding Profile.KdRatio, Converter={StaticResource KdColor}}"/>
                    </StackPanel>
                </Border>

                <!-- Kazanma % -->
                <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="12" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="Kazanma %" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Text="{Binding Profile.WinRate, StringFormat={}{0:F1}%}"
                                   Foreground="{Binding Profile.WinRate, Converter={StaticResource WrColor}}"/>
                    </StackPanel>
                </Border>

                <!-- ACS -->
                <Border Grid.Column="4" Background="#1E1E1E" CornerRadius="12" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="ACS" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Text="{Binding Profile.Acs, StringFormat={}{0:F0}}"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- HS% -->
                <Border Grid.Column="6" Background="#1E1E1E" CornerRadius="12" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="HS%" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Text="{Binding Profile.HeadshotPct, StringFormat={}{0:F1}%}"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Ek Istatistikler -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Toplam Mac" FontSize="11" Foreground="#888888" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Profile.TotalMatches}" FontSize="18"
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Hasar/Tur" FontSize="11" Foreground="#888888" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Profile.DamagePerRound, StringFormat={}{0:F0}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Background="#1E1E1E" CornerRadius="12" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Oynama Suresi" FontSize="11" Foreground="#888888" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Profile.TotalPlaytimeHours, StringFormat={}{0:F0} saat}"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- En Cok Oynanan Ajanlar -->
            <Border Background="#1E1E1E" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="En Cok Oynanan Ajanlar" FontSize="14" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Profile.TopAgents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="8" Padding="16,12"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding AgentName}"
                                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                                   VerticalAlignment="Center" Width="100"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" Foreground="#888888">
                                                <Run Text="{Binding MatchesPlayed}"/>
                                                <Run Text=" mac"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="16,0" VerticalAlignment="Center">
                                            <TextBlock Text="K/D" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{Binding KdRatio, StringFormat={}{0:F2}}"
                                                       FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Margin="16,0" VerticalAlignment="Center">
                                            <TextBlock Text="Kazanma" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                                       FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Margin="16,0" VerticalAlignment="Center">
                                            <TextBlock Text="ACS" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{Binding Acs, StringFormat={}{0:F0}}"
                                                       FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="5" Margin="16,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="HS%" FontSize="10" Foreground="#888888"/>
                                            <TextBlock Text="{Binding HeadshotPct, StringFormat={}{0:F1}%}"
                                                       FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Mac Gecmisi -->
            <Border Background="#1E1E1E" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Son Maclar" FontSize="14" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Matches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="8"
                                        Margin="0,0,0,6" Padding="0">
                                    <Grid>
                                        <Border Width="4" HorizontalAlignment="Left"
                                                CornerRadius="8,0,0,8"
                                                Background="{Binding HasWon, Converter={StaticResource WinColor}}"/>
                                        <Grid Margin="12,12,16,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MapName}" FontSize="12"
                                                           FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding ModeName}" FontSize="10"
                                                           Foreground="#888888"/>
                                                <TextBlock Text="{Binding TimeAgo}" FontSize="10"
                                                           Foreground="#666666"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding AgentName}"
                                                       FontSize="12" Foreground="#AAAAAA"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" Text="{Binding ScoreDisplay}"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"
                                                       VerticalAlignment="Center" Margin="16,0"/>

                                            <TextBlock Grid.Column="3" Text="{Binding KdaDisplay}"
                                                       FontSize="12" FontWeight="Bold" Foreground="White"
                                                       VerticalAlignment="Center" Margin="16,0"/>

                                            <StackPanel Grid.Column="4" Margin="16,0" VerticalAlignment="Center">
                                                <TextBlock Text="ACS" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="{Binding Acs, StringFormat={}{0:F0}}"
                                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                                <TextBlock Text="HS%" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="{Binding HeadshotPct, StringFormat={}{0:F1}%}"
                                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Daha Fazla Yukle -->
                    <Button Content="Daha Fazla Yukle" Margin="0,12,0,0"
                            Height="40" Background="#252525" Foreground="#AAAAAA"
                            FontSize="12" FontWeight="SemiBold" BorderThickness="0"
                            Cursor="Hand" Click="LoadMoreBtn_Click"
                            Visibility="{Binding HasMoreMatches, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#303030"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Bos Durum -->
        <Border Background="#1E1E1E" CornerRadius="12" Padding="40,60" Margin="0,0,0,16"
                Visibility="{Binding HasData, Converter={StaticResource InvBoolToVis}}">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#128269;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Oyuncu aramak icin yukardaki formu kullanin"
                           FontSize="14" Foreground="#888888" HorizontalAlignment="Center"/>
                <TextBlock Text="Ornek: TenZ#000" FontSize="12" Foreground="#555555"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
