<UserControl x:Class="ValorantAutoClicker.Views.AnalizPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:ValorantAutoClicker.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <h:StringToVisibilityConverter x:Key="StrToVis"/>
        <h:PerformansRenkConverter x:Key="PRenkConv"/>
        <h:PerformansGenislikConverter x:Key="PGenislikConv"/>
        <h:PerformansBarConverter x:Key="PBarConv"/>
        <h:WinColorConverter x:Key="MacSonucRenkConv"/>
        <h:BoolToRenkConverter x:Key="MacSonucBgConv"/>
        <h:MacKdRenkConverter x:Key="KdRenkConv"/>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <StackPanel>

            <!-- YUKLENIYOR -->
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" Margin="0,60,0,0">
                <TextBlock Text="Veriler yukleniyor..." FontSize="12" Foreground="#555555"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ProgressBar IsIndeterminate="True" Height="2" Width="180"
                             Background="#252525" Foreground="#555555"/>
            </StackPanel>

            <!-- HATA -->
            <Border Background="#1A0808" CornerRadius="10" Padding="20,16"
                    BorderBrush="#FF4655" BorderThickness="1"
                    HorizontalAlignment="Center" Margin="0,50,0,0" MaxWidth="380"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Veri yuklenemedi" FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FFAAAA"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,14"/>
                    <Button Content="Tekrar Dene" Height="34" Padding="18,0" Cursor="Hand"
                            Command="{Binding YenileCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#252525" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ANA ICERIK -->
            <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

                <!-- SEKMELER (en üstte) -->
                <Border x:Name="SekmeCubugu" Background="#141414" BorderBrush="#222222"
                        BorderThickness="1" CornerRadius="10" Margin="0,0,0,16"
                        SizeChanged="SekmeCubugu_SizeChanged">
                    <Grid x:Name="SekmeGrid" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TabUnderline" Grid.Column="0"
                                Width="0" Height="2" Background="White"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="0,0,0,6" IsHitTestVisible="False">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="UnderlineTranslate"/>
                            </Border.RenderTransform>
                        </Border>

                        <Button Grid.Column="0" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="0"
                                Background="{Binding TabIstatistikler, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0"
                                            BorderThickness="0"
                                            Background="{TemplateBinding Background}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabIstatistikler}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="İstatistikler" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabIstatistikler}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="1" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0" BorderThickness="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabMacGecmisi}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Maç Geçmişi" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabMacGecmisi}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0" BorderThickness="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabCanliMac}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Canlı Maç" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabCanliMac}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- BASLIK -->
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="Performans" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="30" Padding="14,0" Cursor="Hand" Command="{Binding YenileCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#1E1E1E" BorderBrush="#2A2A2A"
                                        BorderThickness="1" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="Yenile" FontSize="11" Foreground="#777777"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ISTATISTIKLER TAB -->
                <StackPanel x:Name="IcerikIstatistikler" Visibility="{Binding TabIstatistikler, Converter={StaticResource BoolToVis}}">

                <!-- 3x2 METRIK KUTUSU -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ═══ SATIR 1 ═══ -->

                        <!-- Kazanma Orani [0] -->
                        <Border x:Name="Metrik0" Grid.Row="0" Grid.Column="0" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="0"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[0].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[0].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[0].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[0].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[0].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[0].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik0Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[0].Deger"/>
                                                <Binding Path="PerformansMetrikleri[0].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ADR [1] -->
                        <Border x:Name="Metrik1" Grid.Row="0" Grid.Column="2" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="1"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[1].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[1].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[1].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[1].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[1].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[1].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik1Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[1].Deger"/>
                                                <Binding Path="PerformansMetrikleri[1].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- K/R [2] -->
                        <Border x:Name="Metrik2" Grid.Row="0" Grid.Column="4" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="2"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[2].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[2].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[2].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[2].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[2].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[2].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik2Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[2].Deger"/>
                                                <Binding Path="PerformansMetrikleri[2].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Background="#222222"/>
                        <Border Grid.Row="0" Grid.Column="3" Background="#222222"/>

                        <!-- ═══ AYIRICI ═══ -->
                        <Border Grid.Row="1" Grid.ColumnSpan="5" Background="#222222" Height="1"/>

                        <!-- ═══ SATIR 2 ═══ -->

                        <!-- Bitis Basarisi [3] -->
                        <Border x:Name="Metrik3" Grid.Row="2" Grid.Column="0" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="3"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[3].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[3].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[3].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[3].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[3].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[3].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik3Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[3].Deger"/>
                                                <Binding Path="PerformansMetrikleri[3].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Giris Basarili [4] -->
                        <Border x:Name="Metrik4" Grid.Row="2" Grid.Column="2" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="4"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[4].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[4].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[4].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[4].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[4].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[4].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik4Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[4].Deger"/>
                                                <Binding Path="PerformansMetrikleri[4].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Ace/4K/3K [5] -->
                        <Border x:Name="Metrik5" Grid.Row="2" Grid.Column="4" Padding="14,14,14,12" Cursor="Hand" Background="Transparent" BorderThickness="0,0,0,1">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding PerformansSecCommand}" CommandParameter="5"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{Binding PerformansMetrikleri[5].DegerText}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="5,2,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[5].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[5].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[5].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[5].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[5].Adi}"
                                           FontSize="10" Foreground="#555555" Margin="0,0,0,8"/>
                                <Grid Height="3">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Border x:Name="Metrik5Bar" CornerRadius="2" HorizontalAlignment="Left" Width="0">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource PRenkConv}">
                                                <Binding Path="PerformansMetrikleri[5].Deger"/>
                                                <Binding Path="PerformansMetrikleri[5].Maksimum"/>
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="1" Background="#222222"/>
                        <Border Grid.Row="2" Grid.Column="3" Background="#222222"/>

                    </Grid>
                </Border>

                <!-- ═══ DETAY PANELI ═══ -->
                <Border x:Name="DetayPanel" Visibility="Collapsed"
                        Background="#1A1A1A" BorderBrush="#222222" BorderThickness="1"
                        CornerRadius="12" Padding="20,18" Margin="0,12,0,0">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="DetayPanelSlide" X="300"/>
                    </Border.RenderTransform>
                    <Grid>
                        <!-- KAPAT -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="28" Height="28" Margin="0,0,0,0" Cursor="Hand"
                                Command="{Binding DetayPanelKapatCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="#252525" CornerRadius="6"
                                            BorderThickness="0">
                                        <TextBlock Text="✕" FontSize="12" Foreground="#777777"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Kazanma Orani Detay -->
                        <StackPanel x:Name="DetayKazanmaOrani" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Kazanma Orani" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Son 10" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KazanmaOraniDetay.Son10MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Son 20" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KazanmaOraniDetay.Son20MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Son 50" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KazanmaOraniDetay.Son50MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12" Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="6" Background="#00D26A" VerticalAlignment="Bottom"
                                        Height="{Binding KazanmaOraniDetay.KazanilanYukseklik, Converter={StaticResource PBarConv}, ConverterParameter=100}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding KazanmaOraniDetay.KazanilanMac}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="G" FontSize="9" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" CornerRadius="6" Background="#FF4655" VerticalAlignment="Bottom"
                                        Height="{Binding KazanmaOraniDetay.KaybedilenYukseklik, Converter={StaticResource PBarConv}, ConverterParameter=100}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding KazanmaOraniDetay.KaybedilenMac}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="K" FontSize="9" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="En cok kazanilan harita" FontSize="10" Foreground="#444444" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding KazanmaOraniDetay.EnCokKazanilanHarita}" FontSize="12" Foreground="#00D26A" Margin="0,0,0,8"/>
                                <TextBlock Text="En cok kaybedilen harita" FontSize="10" Foreground="#444444" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding KazanmaOraniDetay.EnCokKaybedilenHarita}" FontSize="12" Foreground="#FF4655"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- ADR Detay -->
                        <StackPanel x:Name="DetayAdr" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="ADR" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="En Yuksek" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding AdrDetay.EnYuksekAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Ortalama" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding AdrDetay.OrtalamaAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="En Dusuk" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding AdrDetay.EnDusukAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Canvas x:Name="AdrGrafikCanvas" Height="80" Background="Transparent"
                                    Margin="0,0,0,10" SizeChanged="AdrGrafikCanvas_SizeChanged"/>
                            <TextBlock Text="Haritalara gore ADR" FontSize="10" Foreground="#444444" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding AdrDetay.HaritaAdrListe}" Margin="0,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding HaritaAdi}" FontSize="10" Foreground="#666666"/>
                                            <Border Grid.Column="1" Height="4" CornerRadius="2" Background="#252525" Margin="4,0">
                                                <Border CornerRadius="2" HorizontalAlignment="Left" Background="#FF8C00"
                                                        Width="{Binding Adr, Converter={StaticResource PBarConv}, ConverterParameter=250}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Adr, StringFormat={}{0:F0}}" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- K/R Detay -->
                        <StackPanel x:Name="DetayKr" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="K/R" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Kill" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamKill}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Death" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamDeath}" FontSize="18" FontWeight="Bold" Foreground="#FF4655" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Asist" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamAsist}" FontSize="18" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#141414" CornerRadius="8" Padding="12,10" BorderBrush="#252525" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding KrDetay.KarsilastirmaText}" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Bitis Basarisi Detay -->
                        <StackPanel x:Name="DetayBitisBasarisi" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Bitis Basarisi (Clutch)" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <TextBlock Text="{Binding BitisBasarisiDetay.ToplamBasariOrani, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Genel basari orani" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v1Basarili, StringFormat={}{0}}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="/" FontSize="10" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v1, StringFormat={}1v1 {0}}" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v2Basarili, StringFormat={}{0}}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="/" FontSize="10" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v2, StringFormat={}1v2 {0}}" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v3Basarili, StringFormat={}{0}}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="/" FontSize="10" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v3, StringFormat={}1v3 {0}}" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v4Basarili, StringFormat={}{0}}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="/" FontSize="10" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v4, StringFormat={}1v4 {0}}" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v5Basarili, StringFormat={}{0}}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="/" FontSize="10" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BitisBasarisiDetay.Clutch1v5, StringFormat={}1v5 {0}}" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Giris Basarisi Detay -->
                        <StackPanel x:Name="DetayGirisBasarisi" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Giris Basarisi (First Blood)" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Basari Orani" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GirisBasarisiDetay.BasariOrani, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Mac" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GirisBasarisiDetay.ToplamMac}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Haritalara gore giris basarisi" FontSize="10" Foreground="#444444" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding GirisBasarisiDetay.HaritaListe}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding HaritaAdi}" FontSize="10" Foreground="#666666"/>
                                            <Border Grid.Column="1" Height="4" CornerRadius="2" Background="#252525" Margin="4,0">
                                                <Border CornerRadius="2" HorizontalAlignment="Left" Background="#00D26A"
                                                        Width="{Binding BasariOrani, Converter={StaticResource PBarConv}, ConverterParameter=100}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding BasariOrani, StringFormat={}{0:F1}%}" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- MultiKill Detay -->
                        <StackPanel x:Name="DetayMultiKill" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Ace / 4K / 3K" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Ace" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MultiKillDetay.Ace}" FontSize="20" FontWeight="Bold" Foreground="#FF2D55" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="4K" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MultiKillDetay.FourK}" FontSize="20" FontWeight="Bold" Foreground="#FF9500" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="3K" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MultiKillDetay.ThreeK}" FontSize="20" FontWeight="Bold" Foreground="#FFCC00" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="2K" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MultiKillDetay.TwoK}" FontSize="20" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Son multi-kill'ler" FontSize="10" Foreground="#444444" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding MultiKillDetay.MultiKillListe}" MaxHeight="100">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="3" Padding="4,1" Background="#252525">
                                                <TextBlock Text="{Binding Tur}" FontSize="9" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding HaritaAdi}" FontSize="10" Foreground="#666666" Margin="6,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding MacText}" FontSize="9" Foreground="#444444" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ ILERLEME BOLUMU ═══ -->
                <Grid Margin="0,32,0,16">
                    <TextBlock Text="Ilerleme" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </Grid>

                <!-- ELO Grafik + Ozet (YENI TASARIM) -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1" CornerRadius="12" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- SOL: Grafik Alani -->
                        <Grid Grid.Column="0" Margin="0">
                            <TextBlock Text="ELO" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="20,16,0,0"
                                       VerticalAlignment="Top" HorizontalAlignment="Left"/>
                            <Canvas x:Name="EloCanvas" Height="300" Background="Transparent"
                                    SizeChanged="EloCanvas_SizeChanged"
                                    MouseMove="EloGrafik_MouseMove" MouseLeave="EloGrafik_MouseLeave">
                                <Border x:Name="EloTooltipBorder" Background="#1A1A1A" BorderBrush="#333333"
                                        BorderThickness="1" CornerRadius="8" Padding="14,8"
                                        Visibility="Collapsed" IsHitTestVisible="False">
                                    <TextBlock x:Name="EloTooltipValue" FontSize="18" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                            </Canvas>
                            <Canvas x:Name="EloXEksen" Height="18" Background="Transparent"
                                    SizeChanged="EloXEksen_SizeChanged" Margin="0,0,0,8"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- SAG: Ozet Paneli -->
                        <Border Grid.Column="1" Background="#111111" CornerRadius="0,12,12,0" Padding="20,20">
                            <StackPanel>
                                <!-- ELO Farki (buyuk) -->
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock x:Name="EloFarkDegeri" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Son 20 maçtaki Elo farki" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- En Yuksek Elo -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="En Yüksek" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloMaxDegeri" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </Grid>

                                <!-- En Dusuk Elo -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="En Düsük" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloMinDegeri" FontSize="16" FontWeight="Bold" Foreground="#888888"/>
                                </Grid>

                                <!-- Galibiyet % -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Galibiyet" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloWinRateDegeri" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </Grid>

                                <!-- Oynanan Mac -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Maç" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloTotalDegeri" FontSize="16" FontWeight="Bold" Foreground="#AAAAAA"/>
                                </Grid>

                                <!-- Win / Loss Bar -->
                                <Border CornerRadius="4" Height="8" Margin="0,0,0,14" Background="#2A2A2A">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="EloWinBarCol" Width="*"/>
                                            <ColumnDefinition x:Name="EloLossBarCol" Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#00D26A" CornerRadius="4,0,0,4" Margin="0,0,1,0"/>
                                        <Border Grid.Column="1" Background="#FF4655" CornerRadius="0,4,4,0"/>
                                    </Grid>
                                </Border>

                                <!-- W / K sayilari -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="EloWinsText" FontSize="13" FontWeight="Bold" Foreground="#00D26A"/>
                                    <TextBlock Grid.Column="1" Text="/" FontSize="11" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="EloLossesText" FontSize="13" FontWeight="Bold" Foreground="#FF4655"/>
                                </Grid>

                                <!-- W / K kutucuklar -->
                                <ItemsControl ItemsSource="{Binding MmrMacListesi}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" CornerRadius="3" Margin="1.5,1.5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2A1A1A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Kazandi}" Value="True">
                                                                <Setter Property="Background" Value="#1A2A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="8" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="K"/>
                                                            <Setter Property="Foreground" Value="#FF4655"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kazandi}" Value="True">
                                                                    <Setter Property="Text" Value="W"/>
                                                                    <Setter Property="Foreground" Value="#00D26A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ AKTIVITE BOLUMU ═══ -->
                <Grid Margin="0,32,0,16">
                    <TextBlock Text="Aktivite" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </Grid>

                <!-- UST: Saatlik + Haftalik yan yana -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SOL: Saatlik -->
                    <Border Grid.Column="0" Background="#141414" BorderBrush="#222222"
                            BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <!-- Baslik satiri -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SaatlikOzet.OrtalamaGunlukMac, StringFormat={}{0:F1}}"
                                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,3,0,0">
                                            <TextBlock Text="▼" FontSize="10" Foreground="#FF4655"/>
                                            <TextBlock Text="{Binding SaatlikOzet.GunlukDegisim, StringFormat={}{0:F1}}"
                                                       FontSize="10" Foreground="#FF4655" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Ortalama gunluk maclar" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Ellipse Width="7" Height="7" Fill="#00D26A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Galibiyetler" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Oynanan Maclar" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <!-- Grafik canvas -->
                            <Canvas x:Name="SaatlikCanvas" Height="90" Background="Transparent"
                                    SizeChanged="SaatlikCanvas_SizeChanged"
                                    MouseMove="SaatlikCanvas_MouseMove" MouseLeave="SaatlikCanvas_MouseLeave"/>
                            <!-- X ekseni: 0, 6, 12, 18, 24 -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="0" FontSize="9" Foreground="#444444"/>
                                <TextBlock Grid.Column="1" Text="6" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="12" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="18" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="24" FontSize="9" Foreground="#444444"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SAG: Haftalik -->
                    <Border Grid.Column="2" Background="#141414" BorderBrush="#222222"
                            BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <!-- Baslik satiri -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding HaftalikOzet.OrtalamaHaftalikMac, StringFormat={}{0:F1}}"
                                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,3,0,0">
                                            <TextBlock Text="▼" FontSize="10" Foreground="#FF4655"/>
                                            <TextBlock Text="{Binding HaftalikOzet.HaftalikDegisim, StringFormat={}{0:F1}}"
                                                       FontSize="10" Foreground="#FF4655" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Ortalama haftalik maclar" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Ellipse Width="7" Height="7" Fill="#00D26A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Galibiyetler" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Oynanan Maclar" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <!-- Grafik canvas -->
                            <Canvas x:Name="HaftalikCanvas" Height="90" Background="Transparent"
                                    SizeChanged="HaftalikCanvas_SizeChanged"
                                    MouseMove="HaftalikCanvas_MouseMove" MouseLeave="HaftalikCanvas_MouseLeave"/>
                            <!-- X ekseni: gun adlari -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pzt" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Sal" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Car" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Per" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Cum" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Cmt" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Paz" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ALT: Aktivite Takvimi (GitHub tarzı) -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                        CornerRadius="12" Padding="16,14" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Ay baslik satiri -->
                        <Canvas x:Name="TakvimAyCanvas" Height="16" Background="Transparent"
                                SizeChanged="TakvimAyCanvas_SizeChanged" Margin="32,0,0,2"/>

                        <!-- Gun adlari + Hucre grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sol: Gun adlari (P S C P C C P) -->
                            <StackPanel Grid.Column="0" Margin="0,1,0,0">
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="S"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                            </StackPanel>

                            <!-- Sag: Hucre grid (Canvas ile cizilecek) -->
                            <Canvas Grid.Column="1" x:Name="TakvimCanvas" Height="112"
                                    Background="Transparent" SizeChanged="TakvimCanvas_SizeChanged"
                                    MouseMove="TakvimCanvas_MouseMove" MouseLeave="TakvimCanvas_MouseLeave"/>
                        </Grid>

                        <!-- Aciklama satiri -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Oynanan Oyunlar" FontSize="10" Foreground="#444444"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#3D1A5C" Margin="0,0,4,0"/>
                            <TextBlock Text="Dusuk" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#7B2FBE" Margin="0,0,4,0"/>
                            <TextBlock Text="Orta" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#C840E9" Margin="0,0,4,0"/>
                            <TextBlock Text="Yuksek" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#FF2D9B" Margin="0,0,4,0"/>
                            <TextBlock Text="Fusya" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#252525" Margin="0,0,4,0"/>
                            <TextBlock Text="Oyun Yok" FontSize="9" Foreground="#555555" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                </StackPanel>

                <!-- MAC GECMISI TAB -->
                <StackPanel x:Name="IcerikMacGecmisi" Visibility="{Binding TabMacGecmisi, Converter={StaticResource BoolToVis}}">

                    <!-- Header satiri (kutucuksuz, sadece kalin yazi) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="2*" MinWidth="140"/>
                            <ColumnDefinition Width="*" MinWidth="70"/>
                            <ColumnDefinition Width="*" MinWidth="80"/>
                            <ColumnDefinition Width="*" MinWidth="55"/>
                            <ColumnDefinition Width="*" MinWidth="50"/>
                            <ColumnDefinition Width="2*" MinWidth="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="TARİH" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="PUAN" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="DEĞERLENDİRME" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="K/D/A" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="K/D" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="ADR" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="HARİTA" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Ayrac cizgisi -->
                    <Rectangle Height="1" Fill="#1A1A1A" Margin="0,0,0,6"/>

                    <!-- Scrollable liste -->
                    <ScrollViewer x:Name="MacGecmisiScroll" MaxHeight="520"
                                  ScrollChanged="MacGecmisiScroll_ScrollChanged"
                                  VerticalScrollBarVisibility="Hidden"
                                  Background="Transparent" BorderThickness="0">
                        <ItemsControl ItemsSource="{Binding MacGecmisiListesi}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                            CornerRadius="6" Margin="0,0,0,6" Height="52"
                                            Loaded="MacGecmisiRow_Loaded" Padding="0"
                                            MouseEnter="MacSatir_MouseEnter" MouseLeave="MacSatir_MouseLeave">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="2*" MinWidth="140"/>
                                                <ColumnDefinition Width="*" MinWidth="70"/>
                                                <ColumnDefinition Width="*" MinWidth="80"/>
                                                <ColumnDefinition Width="*" MinWidth="55"/>
                                                <ColumnDefinition Width="*" MinWidth="50"/>
                                                <ColumnDefinition Width="2*" MinWidth="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Sol kenar cizgisi -->
                                            <Rectangle Grid.ColumnSpan="9"
                                                       Width="3" Height="36"
                                                       Fill="{Binding Kazandi, Converter={StaticResource MacSonucRenkConv}}"
                                                       Margin="4,8,0,8"
                                                       HorizontalAlignment="Left"
                                                       RadiusX="1" RadiusY="1"/>

                                            <!-- Tarih -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding TarihUst}" FontSize="10"
                                                           Foreground="#CCCCCC" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding TarihAlt}" FontSize="9"
                                                           Foreground="#777777" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <!-- Puan: W/K badge + skor -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Margin="4,0">
                                                <Border Width="20" Height="20" CornerRadius="4"
                                                        Background="{Binding Kazandi, Converter={StaticResource MacSonucBgConv}}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SkorKutucukText}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <TextBlock Text="{Binding SkorBizim, Mode=OneWay}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{Binding SkorBizimRenk}"/>
                                                    <TextBlock Text=" : " FontSize="11" Foreground="#555555" Margin="1,0"/>
                                                    <TextBlock Text="{Binding SkorOnlar, Mode=OneWay}" FontSize="11"
                                                               Foreground="{Binding SkorOnlarRenk}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Orta alan: Mod + ELO + RR -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal" Margin="4,0">
                                                <TextBlock Text="{Binding ModText}" FontSize="11"
                                                           Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding EloText, StringFormat=' • {0}'}"
                                                           FontSize="11" Foreground="#CCCCCC"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding EloVisible, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0"
                                                            Visibility="{Binding RrVisible, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="▲" FontSize="8" Foreground="#00D26A"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding RrPozitif, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="▼" FontSize="8" Foreground="#FF4655"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding RrNegatif, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding RrText}" FontSize="11"
                                                               Foreground="{Binding Kazandi, Converter={StaticResource MacSonucRenkConv}}"
                                                               VerticalAlignment="Center" Margin="2,0,0,0"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Degerlendirme: renkli KD kutucugu -->
                                            <Border Grid.Column="4" Width="64" Height="26" CornerRadius="4"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Background="{Binding KdOran, Converter={StaticResource KdRenkConv}}">
                                                <TextBlock Text="{Binding KdText}" FontSize="12" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- K/D/A -->
                                            <TextBlock Grid.Column="5" Text="{Binding KdaText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- K/D -->
                                            <TextBlock Grid.Column="6" Text="{Binding KdText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- ADR -->
                                            <TextBlock Grid.Column="7" Text="{Binding AdrText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- Harita -->
                                            <StackPanel Grid.Column="8" VerticalAlignment="Center" Margin="6,0,12,0">
                                                <TextBlock Text="{Binding HaritaAdi}" FontSize="12"
                                                           Foreground="#CCCCCC" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding AjanAdi}" FontSize="10"
                                                           Foreground="#777777" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Yukleniyor daha fazla -->
                    <StackPanel Visibility="{Binding IsLoadingMore, Converter={StaticResource BoolToVis}}"
                                Margin="0,4,0,0" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Height="2" Width="120"
                                     Background="#252525" Foreground="#555555"/>
                        <TextBlock Text="Daha fazla yükleniyor..." FontSize="10" Foreground="#555555"
                                   Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- CANLI MAC TAB -->
                <StackPanel x:Name="IcerikCanliMac" Visibility="{Binding TabCanliMac, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Canlı Maç" FontSize="16" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,40,0,0"/>
                    <TextBlock Text="Yakında" FontSize="12" Foreground="#555555"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
