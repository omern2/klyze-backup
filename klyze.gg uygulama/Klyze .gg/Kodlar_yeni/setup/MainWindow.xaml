<Window x:Class="KlyzeSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klyze Kurulum Rehberi"
        Width="560" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="PageTitle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid x:Name="PageWelcome" Visibility="Visible" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Klyze v3.9.9 Kurulumu" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="Valorant oyuncuları için geliştirilmiş araç seti" FontSize="12" Foreground="#555555" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,16"/>
                    <Border Background="#F0F0F0" Padding="16" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Bu kurulum şunları yapacak:" FontSize="11" Foreground="#333333" Margin="0,0,0,8"/>
                            <TextBlock Text="✓  Klyze uygulamasını bilgisayarınıza kuracak" FontSize="11" Foreground="#555555" Margin="8,0,0,2"/>
                            <TextBlock Text="✓  Masaüstü kısayolu oluşturacak" FontSize="11" Foreground="#555555" Margin="8,0,0,2"/>
                            <TextBlock Text="✓  Başlat menüsüne ekleyecek" FontSize="11" Foreground="#555555" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid x:Name="PageLicense" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Kullanım Koşulları" Style="{StaticResource PageTitle}"/>
                    <Border Background="#F0F0F0" Padding="12" MaxHeight="180">
                        <ScrollViewer>
                            <TextBlock Text="Klyze yazılımı, Valorant oyuncuları için geliştirilmiş bir araç setidir. Bu yazılım, Riot Games'in Hizmet Şartları'na uygun olarak tasarlanmıştır. Kullanıcı, yazılımı kendi sorumluluğunda kullanmayı kabul eder. Yazılım, herhangi bir garanti olmaksızın 'olduğu gibi' sunulmaktadır. Geliştirici, yazılımın kullanımından doğabilecek herhangi bir zarardan sorumlu değildir." FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                        </ScrollViewer>
                    </Border>
                    <CheckBox x:Name="LicenseCheck" Content="Koşulları kabul ediyorum" FontSize="11" Margin="0,10,0,0" Checked="LicenseCheck_Changed" Unchecked="LicenseCheck_Changed"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="PagePath" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Kurulum Konumu" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="Klyze'nin kurulacağı klasörü seçin:" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border Background="#F0F0F0" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="InstallPathText" Grid.Column="0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1" Content="Değiştir" FontSize="11" Padding="8,2" Margin="4,0,0,0" Click="BrowsePath_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid x:Name="PageProgress" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Width="400">
                    <TextBlock x:Name="ProgressTitle" Text="Kuruluyor..." Style="{StaticResource PageTitle}"/>
                    <ProgressBar x:Name="ProgressBar" Height="8" Foreground="#4CAF50" Maximum="100"/>
                    <TextBlock x:Name="ProgressText" Text="Dosyalar hazırlanıyor..." FontSize="11" Foreground="#555555" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="ProgressDetail" Text="" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="PageComplete" Visibility="Collapsed" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Kurulum Tamamlandı!" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Klyze başarıyla bilgisayarınıza kuruldu." FontSize="12" Foreground="#555555" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                    <Border Background="#F0F0F0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Kurulan dosyalar:" FontSize="11" Foreground="#333333" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FinalPathText" FontSize="10" Foreground="#555555"/>
                            <TextBlock Text="Masaüstü kısayolu oluşturuldu" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <CheckBox x:Name="LaunchCheck" Content="Klyze'yi başlat" FontSize="11" Margin="0,10,0,0" IsChecked="True"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="0" Content="← Geri" FontSize="12" Padding="16,4" Visibility="Collapsed" Click="BackBtn_Click"/>
            <TextBlock Grid.Column="1" x:Name="StepText" Text="1/5" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button x:Name="NextBtn" Grid.Column="2" Content="İleri →" FontSize="12" Padding="16,4" IsDefault="True" Click="NextBtn_Click"/>
        </Grid>
    </Grid>
</Window>
