                                    <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Crosshair Ayarları" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,16"/>
                                            
                                            <!-- Renk -->
                                            <Grid Margin="0,0,0,12">
                                                <TextBlock Text="Renk" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextWhite}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button x:Name="ColorRed" Width="24" Height="24" Background="#FF4655" Margin="2" Click="CrosshairColor_Click" Tag="Red" BorderThickness="0"/>
                                                    <Button x:Name="ColorGreen" Width="24" Height="24" Background="#00FF41" Margin="2" Click="CrosshairColor_Click" Tag="Green" BorderThickness="0"/>
                                                    <Button x:Name="ColorBlue" Width="24" Height="24" Background="#00D4FF" Margin="2" Click="CrosshairColor_Click" Tag="Blue" BorderThickness="0"/>
                                                    <Button x:Name="ColorYellow" Width="24" Height="24" Background="#FFFF00" Margin="2" Click="CrosshairColor_Click" Tag="Yellow" BorderThickness="0"/>
                                                    <Button x:Name="ColorPurple" Width="24" Height="24" Background="#FF00FF" Margin="2" Click="CrosshairColor_Click" Tag="Purple" BorderThickness="0"/>
                                                    <Button x:Name="ColorWhite" Width="24" Height="24" Background="White" Margin="2" Click="CrosshairColor_Click" Tag="White" BorderThickness="0"/>
                                                    <Button x:Name="ColorCyan" Width="24" Height="24" Background="#00FFFF" Margin="2" Click="CrosshairColor_Click" Tag="Cyan" BorderThickness="0"/>
                                                    <Button x:Name="ColorOrange" Width="24" Height="24" Background="#FF8000" Margin="2" Click="CrosshairColor_Click" Tag="Orange" BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- İç çizgiler -->
                                            <TextBlock Text="İç çizgiler" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Uzunluk" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="InnerLengthValue" Text="8" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="InnerLengthSlider" Style="{StaticResource MonoSlider}" Minimum="0" Maximum="80" Value="8" Margin="0,0,0,8" ValueChanged="CrosshairSlider_ValueChanged"/>
                                            
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Kalınlık" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="InnerThicknessValue" Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="InnerThicknessSlider" Style="{StaticResource MonoSlider}" Minimum="1" Maximum="30" Value="2" Margin="0,0,0,8" ValueChanged="CrosshairSlider_ValueChanged"/>
                                            
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Boşluk" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="InnerGapValue" Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="InnerGapSlider" Style="{StaticResource MonoSlider}" Minimum="0" Maximum="50" Value="2" Margin="0,0,0,12" ValueChanged="CrosshairSlider_ValueChanged"/>

                                            <!-- Dış çizgiler -->
                                            <CheckBox x:Name="OuterLinesCheckbox" Content="Dış çizgiler" Style="{StaticResource DarkCheck}" Margin="0,0,0,8" Checked="CrosshairCheckbox_Changed" Unchecked="CrosshairCheckbox_Changed"/>
                                            <StackPanel x:Name="OuterLinesPanel" Visibility="Collapsed">
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Uzunluk" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="OuterLengthValue" Text="4" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="OuterLengthSlider" Style="{StaticResource MonoSlider}" Minimum="0" Maximum="60" Value="4" Margin="0,0,0,8" ValueChanged="CrosshairSlider_ValueChanged"/>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Kalınlık" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="OuterThicknessValue" Text="1" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="OuterThicknessSlider" Style="{StaticResource MonoSlider}" Minimum="1" Maximum="20" Value="1" Margin="0,0,0,8" ValueChanged="CrosshairSlider_ValueChanged"/>
                                                
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Dış Boşluk" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="OuterGapValue" Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="OuterGapSlider" Style="{StaticResource MonoSlider}" Minimum="0" Maximum="30" Value="2" Margin="0,0,0,12" ValueChanged="CrosshairSlider_ValueChanged"/>
                                            </StackPanel>

                                            <!-- Merkez Nokta -->
                                            <CheckBox x:Name="CenterDotCheckbox" Content="Merkez Nokta" Style="{StaticResource DarkCheck}" Margin="0,0,0,8" Checked="CrosshairCheckbox_Changed" Unchecked="CrosshairCheckbox_Changed"/>
                                            <StackPanel x:Name="CenterDotPanel" Visibility="Collapsed">
                                                <Grid Margin="0,0,0,8">
                                                    <TextBlock Text="Boyut" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="CenterDotSizeValue" Text="2" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="CenterDotSizeSlider" Style="{StaticResource MonoSlider}" Minimum="1" Maximum="40" Value="2" Margin="0,0,0,12" ValueChanged="CrosshairSlider_ValueChanged"/>
                                            </StackPanel>

                                            <!-- Saydamlık -->
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Saydamlık" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="OpacityValue" Text="100%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentWhite}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="OpacitySlider" Style="{StaticResource MonoSlider}" Minimum="10" Maximum="100" Value="100" ValueChanged="CrosshairSlider_ValueChanged"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Sağ Panel - Önizleme -->
                                <StackPanel Grid.Column="2">
                                    <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="20,16" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Önizleme" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                            <!-- Profil Adı -->
                                            <TextBox x:Name="ProfileNameInput" Style="{StaticResource DarkInput}" Text="Yeni Profil" Margin="0,0,0,16"/>
                                            <!-- Crosshair Önizleme Alanı -->
                                            <Border Background="#0A0A0A" Width="280" Height="180" CornerRadius="8" Margin="0,0,0,16">
                                                <Canvas x:Name="CrosshairPreview" Width="280" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Etkinleştir Butonu -->
                                            <Button x:Name="EnableCrosshairButton" Content="Crosshair Etkinleştir" Style="{StaticResource BigPrimaryBtn}" Margin="0,0,0,12" Click="EnableCrosshairButton_Click"/>
                                            <!-- Bilgi -->
                                            <TextBlock Text="Crosshair'ınızı özelleştirin ve Önizlemede görün" FontSize="11" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- SETTINGS PAGE -->
                    <Grid x:Name="SettingsPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Top">
                        <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="24,20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Kısayol Tuşları" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,16"/>

                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="24,20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Tema" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="LightBtn" Grid.Column="0" Content="Açık" Style="{StaticResource DarkBtn}" Click="LightTheme_Click"/>
                                    <Button x:Name="DarkBtn" Grid.Column="2" Content="Koyu" Style="{StaticResource PrimaryBtn}" Click="DarkTheme_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="Dil" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TrBtn" Grid.Column="0" Content="Türkçe" Style="{StaticResource PrimaryBtn}" Click="Turkish_Click"/>
                                    <Button x:Name="EnBtn" Grid.Column="2" Content="English" Style="{StaticResource DarkBtn}" Click="English_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Hesap Bilgisi + Çıkış -->
                        <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="24,20" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Hesap" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextWhite}" Margin="0,0,0,14"/>
                                <Border Background="{StaticResource CardDark}" CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Image x:Name="SettingsRankIkon" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock x:Name="HesapAdiText" Text="Giriş yapılmadı" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextWhite}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="HesapRutbeText" Text="" FontSize="11" Foreground="{StaticResource TextGray}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#1A3A2A" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                            <TextBlock x:Name="HesapDurumText" Text="Bağlı" FontSize="10" FontWeight="Bold" Foreground="#00D26A"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Button Content="Çıkış Yap" Height="44" Background="#3A0A0A" Foreground="#FF6666"
                                        FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                        Click="CikisYap_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>

                            </StackPanel>
                    </Grid>
                    <!-- SUPPORT PAGE -->
                    <Grid x:Name="SupportPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Çok Yakında" FontSize="24" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Bu özellik yakında eklenecektir." FontSize="13"
                                       Foreground="#888888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <!-- PLAY PAGE -->
                    <Grid x:Name="PlayPage" Visibility="Collapsed">
                        <ContentControl x:Name="PlayPageControl"/>
                    </Grid>

                    <!-- ANALIZ PAGE -->
                    <Grid x:Name="AnalizPage" Visibility="Collapsed">
                        <ContentControl x:Name="AnalizPageControl"/>
                    </Grid>

                    <!-- INFO PAGE -->
                    <Grid x:Name="InfoPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Top">
                        <Border Background="{StaticResource CardBg}" CornerRadius="10" Padding="40,36" Margin="0,0,0,16">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="uygulama_logusu.png" Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="Klyze" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextWhite}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Border Background="#3A3A3A" CornerRadius="4" Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="v3.9.0" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Valorant ve Minecraft için gelişmiş otomasyon aracı." FontSize="13" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Crosshair yönetimi ve sanal mikrofon özellikleri ile oyun deneyiminizi geliştirin." FontSize="12" Foreground="{StaticResource TextGray}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                            </StackPanel>
                        </Border>

                        <!-- GÜNCELLEME -->
                        <Border Background="#1A1A1A" CornerRadius="10" Padding="24,20" BorderBrush="#3A3A3A" BorderThickness="1" Margin="0,16,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Image Source="pack://application:,,,/Assets/Icons/yenile%20icon.png" Width="22" Height="22" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
                                    <TextBlock Text="Güncelleme" FontSize="14" FontWeight="Bold" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                    <Border Background="#EF4444" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="YENİ" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <Border Background="#222222" CornerRadius="8" Padding="16,14" BorderBrush="#333333" BorderThickness="1"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                            <Run Text="Yeni Sürüm Mevcut" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock x:Name="InfoPageVersionText" Text="{Binding RemoteVersion, StringFormat='v{0}'}"
                                                   FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding ReleaseNotes}" FontSize="11" Foreground="#AAAAAA"
                                                   TextWrapping="Wrap" Margin="0,8,0,0" MaxHeight="60"/>
                                        <Button Command="{Binding GuncellemeIndirCommand}" Background="#EF4444" Foreground="White"
                                                Height="38" FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                                Margin="0,12,0,0" HorizontalAlignment="Center" Width="220">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="⬇ Güncellemeyi İndir" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Margin="0,8,0,0" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                                            <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                                         Height="6" Foreground="#EF4444" Background="#333333" BorderThickness="0"/>
                                            <TextBlock Text="{Binding DownloadStatus}" FontSize="11" Foreground="#AAAAAA"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Background="#222222" CornerRadius="8" Padding="16,14" BorderBrush="#333333" BorderThickness="1"
                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="Şu anda en son sürüm kullanılıyor." FontSize="12" Foreground="#888888"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- BİLDİRİMLER (artık sağ üst zilden açılıyor) -->
                        <Border Background="#1A1A1A" CornerRadius="10" Padding="24,20" BorderBrush="#3A3A3A" BorderThickness="1" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Bildirimler sağ üst köşedeki çan ikonuna tıklayarak görüntülenir." 
                                           FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                            </StackPanel>
                    </Grid>

                    <!-- TIMER PAGE -->
                    <Grid x:Name="TimerPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Top" Margin="35,20,35,35">
                            <TextBlock Text="Timer" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Yakında..." FontSize="13" Foreground="#888888" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- FAKE SES PAGE -->
                    <Grid x:Name="FakeMicPage" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Top" Margin="35,20,35,35">

                            <!-- BÖLÜM 1 - Bağlık -->
                            <StackPanel x:Name="FakeMicSection1" Opacity="0">
                                <TextBlock Text="Fake Ses" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Sanal mikrofon ile ses dosyalarınızı oynatın." FontSize="14" Foreground="#888888" Margin="0,6,0,24"/>
                            </StackPanel>

                            <!-- BÖLÜM 2 - Durum Kartı -->
                            <Border x:Name="FakeMicSection2" Opacity="0" Background="#111111" CornerRadius="12" Padding="16" Margin="0,0,0,20" BorderBrush="#12FFFFFF" BorderThickness="1">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="12"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="FakeMicStatusDot" Width="8" Height="8" CornerRadius="4" Background="#555" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FakeMicVM.IsVBCableInstalled}" Value="True">
                                                        <Setter Property="Background" Value="#22c55e"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FakeMicVM.IsVBCableInstalled}" Value="False">
                                                        <Setter Property="Background" Value="#ef4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock x:Name="FakeMicStatusText" Grid.Column="1" Text="VB-Cable kontrol ediliyor..." FontSize="13" Foreground="#aaaaaa" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Border Grid.Column="2" CornerRadius="8" Background="#1a1a1a" BorderBrush="#22FFFFFF" BorderThickness="1" Visibility="Collapsed" Margin="12,0,0,0">
                                        <Button x:Name="FakeMicVbDownloadBtn" Content="VB-Cable İndir" FontSize="12" Foreground="White" Background="Transparent" BorderThickness="0" Padding="12,7" Cursor="Hand" Click="FakeMicVbDownload_Click"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- BÖLÜM 3 - Ekle / Sil Butonları -->
                            <Border x:Name="FakeMicSection3" Opacity="0" Margin="0,0,0,12">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="12"/>
                                </Border.RenderTransform>
                                <StackPanel Orientation="Horizontal">
                                    <Border CornerRadius="8" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                        <Button x:Name="FakeMicAddBtn" Content="+ Ekle" Background="Transparent" Foreground="White" BorderThickness="0" Padding="16,10" Cursor="Hand" FontSize="13" FontWeight="SemiBold" Click="FakeMicAddBtn_Click"/>
                                    </Border>
                                    <Border CornerRadius="8" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="8,0,0,0">
                                        <Button x:Name="FakeMicRemoveBtn" Content="Tümünü Sil" Background="Transparent" Foreground="#ef4444" BorderThickness="0" Padding="16,10" Cursor="Hand" FontSize="13" Click="FakeMicRemoveBtn_Click"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- BÖLÜM 4 - Dosya Kartları -->
                            <ItemsControl x:Name="FakeMicCardsContainer" ItemsSource="{Binding FakeMicVM.Playlist}" Margin="0,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Background="#141414" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="12,6" Margin="0,0,0,6" Height="58">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Dosya adı (tıklayınca düzenlenebilir) -->
                                                <TextBox Grid.Column="0" Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Foreground="White" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,10,0" CaretBrush="White" IsTabStop="False"/>

                                                <!-- Ses slider -->
                                                <Border Grid.Column="1" CornerRadius="4" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="8,2" Margin="0,0,6,0" VerticalAlignment="Center" Height="24">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center" Width="72" Height="14"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding VolumePercent, StringFormat='{}{0}%'}" FontSize="10" Foreground="#aaa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Tuş Ata butonu -->
                                                <Border Grid.Column="2" CornerRadius="4" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Button x:Name="FakeMicBindBtn" Content="{Binding HotkeyDisplay}" Background="Transparent" BorderThickness="0" Padding="8,3" Cursor="Hand" FontSize="11" Click="FakeMicBindBtn_Click" Tag="{Binding}" MinWidth="44">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Foreground" Value="#4ade80"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                                        <Setter Property="Foreground" Value="#ffcc00"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Border>

                                                <!-- Başlat butonu -->
                                                <Border Grid.Column="3" CornerRadius="4" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Button x:Name="FakeMicPlayBtn" Background="Transparent" Foreground="#22c55e" BorderThickness="0" Padding="10,3" Cursor="Hand" FontSize="11" FontWeight="SemiBold" Click="FakeMicPlayBtn_Click" Tag="{Binding}"><StackPanel Orientation="Horizontal"><Image Source="pack://application:,,,/Assets/Icons/oynat%20icon.png" Width="22" Height="22" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,4,0"/><TextBlock Text="Çal" VerticalAlignment="Center" Foreground="#22c55e" FontSize="11" FontWeight="SemiBold"/></StackPanel></Button>
                                                </Border>

                                                <!-- Cihaz seçimi -->
                                                <Border Grid.Column="4" CornerRadius="4" Background="#1a1a1a" BorderBrush="#1AFFFFFF" BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center" Height="24">
                                                    <ComboBox x:Name="FakeMicCardDeviceCombo" ItemsSource="{Binding DataContext.FakeMicVM.OutputDevices, RelativeSource={RelativeSource AncestorType=ItemsControl}}" SelectedIndex="{Binding SelectedDeviceIndex, Mode=TwoWay}" Background="Transparent" Foreground="#ccc" BorderThickness="0" FontSize="11" Height="24" Width="100" Padding="4,0"/>
                                                </Border>

                                                <!-- Sil - -->
                                                <Button Grid.Column="5" Content="-" FontSize="14" Foreground="#ef4444" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Padding="6,0" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Grid>

                        </Grid>
                    </ScrollViewer>
                </Border>
                
                <!-- External Scrollbar -->
                <ScrollBar Grid.Column="1" 
                         Style="{StaticResource MinimalScrollBar}"
                         Orientation="Vertical"
                         Margin="0,28,35,35"
                         Value="{Binding ElementName=MainScrollViewer, Path=VerticalOffset, Mode=OneWay}"
                         Maximum="{Binding ElementName=MainScrollViewer, Path=ScrollableHeight, Mode=OneWay}"
                         ViewportSize="{Binding ElementName=MainScrollViewer, Path=ViewportHeight, Mode=OneWay}"
                         Visibility="{Binding ElementName=MainScrollViewer, Path=ComputedVerticalScrollBarVisibility, Mode=OneWay}"/>
            </Grid>

            <!-- KLYZE AI PAGE - no background, inherits app base -->
            <Grid x:Name="KlyzeAiPage" Visibility="Collapsed" DataContext="{Binding KlyzeAiVM}">
                <!-- ===== WELCOME VIEW ===== -->
                <Grid Visibility="{Binding WelcomeModu, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="620">

                        <!-- Header -->
                        <TextBlock Text="What can I help you ship?"
                                   FontSize="27" FontWeight="Bold" Foreground="#F2F2F0"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,26"/>

                        <!-- Input Box -->
                        <Border x:Name="KlyzeAiInputBorder"
                                MinHeight="88"
                                Background="#1A1A1A"
                                CornerRadius="15"
                                BorderBrush="#12FFFFFF"
                                BorderThickness="0,1,0,0"
                                Padding="16,14,16,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="20"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Text Input Area -->
                                <Grid Grid.Row="0" MinHeight="20">
                                    <TextBox x:Name="KlyzeAiTextBox"
                                             Text="{Binding GirisMetni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Foreground="#F2F2F0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             CaretBrush="#F2F2F0"
                                             VerticalAlignment="Top"
                                             VerticalContentAlignment="Top"
                                             MaxHeight="200"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="Ask v0 a question…"
                                               FontSize="14" Foreground="#666"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Top"
                                               Padding="0,1,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GirisMetni}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GirisMetni}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Toolbar -->
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Paperclip -->
                                    <Border Grid.Column="0" Width="28" Height="28"
                                            Cursor="Hand" ToolTip="Dosya ekle"
                                            Background="Transparent">
                                        <Path Data="M14 7v6a5 5 0 01-10 0V6.5A3.5 3.5 0 017.5 3h1A3.5 3.5 0 0112 6.5V13a2 2 0 01-4 0V7"
                                               Stroke="#777" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                               StrokeLineJoin="Round" Fill="Transparent"
                                               Stretch="Uniform" Margin="4"/>
                                    </Border>

                                    <!-- +Project pill -->
                                    <Border Grid.Column="2"
                                            CornerRadius="999"
                                            BorderBrush="#555" BorderThickness="1.5"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            Margin="0,0,8,0"
                                            Padding="12,6"
                                            x:Name="ProjectPill">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+" Foreground="#888" FontSize="13"
                                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Project" Foreground="#888" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Send button -->
                                    <Border Grid.Column="3"
                                            Width="32" Height="32"
                                            CornerRadius="16"
                                            Background="#2E2E2E"
                                            x:Name="SendBtnBorder">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Button Command="{Binding GonderCommand}"
                                                Style="{StaticResource AiCleanBtn}"
                                                ToolTip="Gönder"
                                                Width="32" Height="32">
                                            <TextBlock Text="↑" Foreground="#CCC" FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </Button>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>


                    </StackPanel>
                </Grid>

                <!-- ===== CHAT VIEW ===== -->
                <Grid Visibility="{Binding WelcomeModu, Converter={StaticResource InvBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Messages area -->
                    <ScrollViewer Grid.Row="0" x:Name="AiChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly"
                                  Margin="35,20,35,0">
                        <ItemsControl ItemsSource="{Binding AktifMesajlar}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" MaxWidth="500"
                                            UseLayoutRounding="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KullaniciMesaji}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border CornerRadius="14" Padding="14,10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#252525"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding KullaniciMesaji}" Value="True">
                                                            <Setter Property="Background" Value="#1A3A5C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <!-- Final content -->
                                                <TextBlock Text="{Binding Icerik}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#F2F2F0"
                                                           FontSize="13"
                                                           LineHeight="20"/>
                                                <!-- Streaming text -->
                                                <TextBlock Text="{Binding StreamingMetin}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#F2F2F0"
                                                           FontSize="13"
                                                           LineHeight="20">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StreamAktif}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Loading dots -->
                                                <TextBlock Text="{Binding DurumEtiketi}"
                                                           Foreground="#888"
                                                           FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Yukleniyor}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Input area (chat bottom) -->
                    <Border Grid.Row="1"
                            Background="#1A1A1A"
                            CornerRadius="15"
                            BorderBrush="#12FFFFFF"
                            BorderThickness="0,1,0,0"
                            Padding="16,12"
                            Margin="35,10,35,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding GirisMetni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Foreground="#F2F2F0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     CaretBrush="#F2F2F0"
                                     MaxHeight="120"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     KeyDown="KlyzeAiGirisKutusu_KeyDown"/>
                            <Border Grid.Column="1"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="#2E2E2E"
                                    Margin="8,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Button Command="{Binding GonderCommand}"
                                        Style="{StaticResource AiCleanBtn}"
                                        ToolTip="Gönder"
                                        Width="32" Height="32">
                                    <TextBlock Text="↑" Foreground="#CCC" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- SAĞ ÇUBUK -->
        <Border Grid.Row="1" Grid.Column="2" Background="#0F0F0F" Panel.ZIndex="10">
            <StackPanel Margin="0,16,0,0">
                <!-- Profil Fotoğrafı - sadece avatar, rank ikonu yok -->
                <Border x:Name="RightBarAvatar" Width="40" Height="40" CornerRadius="20"
                        Background="#2A2A2A" Cursor="Hand"
                        HorizontalAlignment="Center"
                        MouseLeftButtonDown="RightBarAvatar_Click"
                        ToolTip="Profil">
                    <Grid ClipToBounds="True">
                        <Image x:Name="RightBarAvatarImg" Width="40" Height="40"
                               Stretch="UniformToFill" Visibility="Collapsed"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>

                <!-- Ayırıcı Çizgi (kapsül şeklinde, yarıda kesilen) -->
                <Border Width="20" Height="2" CornerRadius="1" Background="#2A2A2A"
                        HorizontalAlignment="Center" Margin="0,10,0,0"/>

                <!-- Bildirim zili (minimalist path) -->
                <Border x:Name="BildirimZili" Width="36" Height="36" HorizontalAlignment="Center" Margin="0,10,0,0"
                        Cursor="Hand" MouseLeftButtonDown="BildirimZili_Click">
                    <Grid>
                        <Path Data="M12 22C13.1 22 14 21.1 14 20H10C10 21.1 10.9 22 12 22ZM18 16V11C18 7.93 16.36 5.36 13.5 4.68V4C13.5 3.17 12.83 2.5 12 2.5S10.5 3.17 10.5 4V4.68C7.64 5.36 6 7.92 6 11V16L4 18V19H20V18L18 16Z"
                              Width="20" Height="20" Stretch="Uniform"
                              Fill="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Kırmızı nokta (güncelleme varsa) -->
                        <Ellipse x:Name="BildirimNokta" Width="8" Height="8" Fill="#EF4444"
                                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                 Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

            <!-- =================================================================== -->
            <!-- PROFİL AÇILIR PANEL – sağ çubuktaki avatar tıklanınca açılır -->
            <!-- =================================================================== -->
            <!-- Dışarı tıklanmayı yakalamak için arka plan katmanı -->
            <Rectangle x:Name="ProfileOverlay" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                       Fill="Transparent" Panel.ZIndex="149" Visibility="Collapsed"
                       MouseLeftButtonDown="ProfileOverlay_Click"/>

            <!-- Açılır panel – Fluent Design tarzı -->
            <!-- =================================================================== -->
            <!-- BİLDİRİM AÇILIR PANELİ – sağ çubuktaki zil tıklanınca açılır -->
            <!-- =================================================================== -->
            <Border x:Name="BildirimDropdownOverlay" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Panel.ZIndex="201" Visibility="Collapsed"
                    Background="Transparent" MouseLeftButtonDown="BildirimDropdownOverlay_Click"/>

            <Border x:Name="BildirimDropdown" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Panel.ZIndex="202" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,56,12,0"
                    Background="#111111"
                    CornerRadius="12"
                    BorderThickness="1" BorderBrush="#2A2A2A"
                    Width="280">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <!-- Durum A: Güncelleme Yok -->
                    <TextBlock x:Name="PanelNoUpdate" Text="Yeni bildirim yok"
                               FontSize="13" Foreground="#666666"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Padding="24" Visibility="Visible"/>

                    <!-- Duyuru Mesajı -->
                    <Border x:Name="PanelBildirim" Visibility="Collapsed"
                            Background="#1A1A2E" CornerRadius="10" Margin="12"
                            BorderThickness="1" BorderBrush="#2A2A4A">
                        <StackPanel Margin="14">
                            <TextBlock x:Name="PanelBildirimBaslik" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock x:Name="PanelBildirimMesaj" FontSize="12" Foreground="#AAAAAA"
                                       TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <!-- Durum B: Güncelleme Var -->
                    <StackPanel x:Name="PanelUpdate" Margin="16" Visibility="Collapsed">
                        <TextBlock Text="Yeni Sürüm Mevcut" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="PanelVersionText" FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <TextBlock x:Name="PanelReleaseNotes" FontSize="12" Foreground="#AAAAAA"
                                       TextWrapping="Wrap" LineHeight="18"/>
                        </ScrollViewer>

                        <!-- Güncelle Butonu -->
                        <Border x:Name="PanelGuncelleBtn" Background="White" CornerRadius="10" Height="40"
                                Margin="0,16,0,0" Cursor="Hand"
                                MouseLeftButtonDown="PanelGuncelleBtn_Click">
                            <Grid>
                                <TextBlock x:Name="PanelGuncelleBtnText" Text="Güncelle"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#000000"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- İlerleme çubuğu (görünmez varsayılan) -->
                                <Border x:Name="PanelProgressTrack" Height="4" CornerRadius="4"
                                        Background="#1A1A1A" VerticalAlignment="Bottom" Margin="8,0,8,6"
                                        Visibility="Collapsed">
                                    <Border x:Name="PanelProgressFill" Height="4" CornerRadius="4"
                                            Background="White" HorizontalAlignment="Left" Width="0"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Hata mesajı + Tekrar Dene -->
                        <StackPanel x:Name="PanelErrorArea" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="PanelErrorText" Text="İndirme Başarısız"
                                       FontSize="12" Foreground="#EF4444" HorizontalAlignment="Center"/>
                            <TextBlock Text="Tekrar Dene" FontSize="11" Foreground="#888888"
                                       HorizontalAlignment="Center" Cursor="Hand" Margin="0,4,0,0"
                                       MouseLeftButtonDown="PanelRetry_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ProfileDropdown" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Panel.ZIndex="150" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,56,52,0"
                    Background="#111111"
                    CornerRadius="12"
                    BorderThickness="0"
                    Width="200">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="20"/>
                </Border.RenderTransform>
                <StackPanel>
                    <!-- Oyuncu Kartı -->
                    <Button x:Name="ProfileCardBtn" Height="44" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="16,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#252525"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Kimlik ikonu -->
                                        <Path Data="M12 12C14.21 12 16 10.21 16 8S14.21 4 12 4 8 5.79 8 8 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z"
                                              Width="16" Height="16" Stretch="Uniform"
                                              Fill="#888888" VerticalAlignment="Center"/>
                                        <TextBlock Text="Oyuncu Kartı" FontSize="13" Foreground="#CCCCCC"
                                                   Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border Height="1" Background="#1C1C1C" Margin="16,0"/>

                    <!-- Hesaptan Çıkış Yap -->
                    <Button x:Name="ProfileLogoutBtn" Height="44" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Click="ProfileLogout_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="16,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#252525"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Çıkış ikonu (dışarı ok) -->
                                        <Path Data="M16 17V19C16 20.1 15.1 21 14 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3H14C15.1 3 16 3.9 16 5V7M10 12H21M18 9L21 12 18 15"
                                              Width="16" Height="16" Stretch="Uniform"
                                              Fill="#666666" VerticalAlignment="Center"/>
                                        <TextBlock Text="Hesaptan Çıkış Yap" FontSize="13" Foreground="#888888"
                                                   Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
              x:Name="LoginOverlay" Panel.ZIndex="200"
              Visibility="{Binding GirisEkraniGoster, Converter={StaticResource BoolToVis}}">
            <ContentControl x:Name="LoginPageControl"/>
        </Grid>

        <!-- GÜNCELLEME OVERLAY - her şeyin üstünde, otomatik açılır -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
              x:Name="UpdateOverlay" Panel.ZIndex="300"
              Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.85"/>
            </Grid.Background>
            <Border Background="#141414" BorderBrush="#333333" BorderThickness="1"
                    CornerRadius="16" Padding="36,32" MaxWidth="400"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Yeni Sürüm Mevcut" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding RemoteVersion, StringFormat='v{0}'}"
                               FontSize="14" Foreground="#888888"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <Border Background="#1A1A2E" CornerRadius="10" Padding="14" Margin="0,0,0,20">
                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ReleaseNotes}" FontSize="12" Foreground="#AAAAAA"
                                       TextWrapping="Wrap" LineHeight="18"/>
                        </ScrollViewer>
                    </Border>
                    <Button x:Name="UpdateBtn" Height="48" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="UpdateBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="White" CornerRadius="12">
                                    <TextBlock Text="İndir ve Kur" FontSize="14" FontWeight="Bold"
                                               Foreground="#0f0d0d"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="UpdateStatusText" FontSize="11" Foreground="#666666"
                               HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <Border x:Name="UpdateProgressBorder" Height="4" CornerRadius="4"
                            Background="#222222" Margin="0,8,0,0" Visibility="Collapsed">
                        <Border x:Name="UpdateProgressFill" Height="4" CornerRadius="4"
                                Background="White" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

            </Grid>
        </Border>
    </Border>
</Window>