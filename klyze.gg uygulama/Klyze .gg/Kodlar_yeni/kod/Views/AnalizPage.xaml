                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Kill" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamKill}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Death" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamDeath}" FontSize="18" FontWeight="Bold" Foreground="#FF4655" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Asist" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding KrDetay.ToplamAsist}" FontSize="18" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#141414" CornerRadius="8" Padding="12,10" BorderBrush="#252525" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding KrDetay.KarsilastirmaText}" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Headshot Detay -->
                        <StackPanel x:Name="DetayHeadshot" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Kafa Vurusu" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HeadshotDetay.HeadshotYuzdesi, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="HS %" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HeadshotDetay.ToplamHeadshot}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Toplam HS" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HeadshotDetay.ToplamBodyshot}" FontSize="24" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Body" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding HeadshotDetay.ToplamLegshot, StringFormat={}Legshot: {0}}" FontSize="11" Foreground="#666666" Margin="0,0,0,14"/>
                            <Border Background="#141414" CornerRadius="8" Padding="12,10" BorderBrush="#252525" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding HeadshotDetay.ToplamHeadshot, StringFormat={}Kafa vurusu: {0}}" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Giris Basarisi Detay -->
                        <StackPanel x:Name="DetayGirisBasarisi" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="Giris Basarisi (First Blood)" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Basari Orani" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GirisBasarisiDetay.BasariOrani, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Toplam Mac" FontSize="10" Foreground="#444444" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GirisBasarisiDetay.ToplamMac}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Haritalara gore giris basarisi" FontSize="10" Foreground="#444444" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding GirisBasarisiDetay.HaritaListe}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding HaritaAdi}" FontSize="10" Foreground="#666666"/>
                                            <Border Grid.Column="1" Height="4" CornerRadius="2" Background="#252525" Margin="4,0">
                                                <Border CornerRadius="2" HorizontalAlignment="Left" Background="#00D26A"
                                                        Width="{Binding BasariOrani, Converter={StaticResource PBarConv}, ConverterParameter=100}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding BasariOrani, StringFormat={}{0:F1}%}" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- MultiKill Detay -->
                        <StackPanel x:Name="DetayAcs" Visibility="Collapsed" Margin="0,0,36,0">
                            <TextBlock Text="ACS (Average Combat Score)" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MultiKillDetay.Ace}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ACS" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MultiKillDetay.FourK}" FontSize="12" FontWeight="Bold" Foreground="#00D26A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Kill Puanı" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MultiKillDetay.ThreeK}" FontSize="12" FontWeight="Bold" Foreground="#FFC030" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Asist Puanı" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#141414" CornerRadius="8" Padding="12,10" BorderBrush="#252525" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding MultiKillDetay.Ace, StringFormat={}Tur Basina ACS: {0}}" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ ILERLEME BOLUMU ═══ -->
                <Grid Margin="0,32,0,16">
                    <TextBlock Text="Ilerleme" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </Grid>

                <!-- ELO Grafik + Ozet (YENI TASARIM) -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1" CornerRadius="12" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- SOL: Grafik Alani -->
                        <Grid Grid.Column="0" Margin="0">
                            <TextBlock Text="ELO" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="20,16,0,0"
                                       VerticalAlignment="Top" HorizontalAlignment="Left"/>
                            <Canvas x:Name="EloCanvas" Height="300" Background="Transparent"
                                    SizeChanged="EloCanvas_SizeChanged"
                                    MouseMove="EloGrafik_MouseMove" MouseLeave="EloGrafik_MouseLeave">
                                <Border x:Name="EloTooltipBorder" Background="#1A1A1A" BorderBrush="#333333"
                                        BorderThickness="1" CornerRadius="8" Padding="14,8"
                                        Visibility="Collapsed" IsHitTestVisible="False">
                                    <TextBlock x:Name="EloTooltipValue" FontSize="18" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                            </Canvas>
                            <Canvas x:Name="EloXEksen" Height="18" Background="Transparent"
                                    SizeChanged="EloXEksen_SizeChanged" Margin="0,0,0,8"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- SAG: Ozet Paneli -->
                        <Border Grid.Column="1" Background="#111111" CornerRadius="0,12,12,0" Padding="20,20">
                            <StackPanel>
                                <!-- ELO Farki (buyuk) -->
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock x:Name="EloFarkDegeri" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Son 20 maçtaki Elo farki" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- En Yuksek Elo -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="En Yüksek" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloMaxDegeri" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </Grid>

                                <!-- En Dusuk Elo -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="En Düsük" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloMinDegeri" FontSize="16" FontWeight="Bold" Foreground="#888888"/>
                                </Grid>

                                <!-- Galibiyet % -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Galibiyet" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloWinRateDegeri" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </Grid>

                                <!-- Oynanan Mac -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Maç" FontSize="10" Foreground="#444444"/>
                                    <TextBlock Grid.Column="1" x:Name="EloTotalDegeri" FontSize="16" FontWeight="Bold" Foreground="#AAAAAA"/>
                                </Grid>

                                <!-- Win / Loss Bar -->
                                <Border CornerRadius="4" Height="8" Margin="0,0,0,14" Background="#2A2A2A">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="EloWinBarCol" Width="*"/>
                                            <ColumnDefinition x:Name="EloLossBarCol" Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#00D26A" CornerRadius="4,0,0,4" Margin="0,0,1,0"/>
                                        <Border Grid.Column="1" Background="#FF4655" CornerRadius="0,4,4,0"/>
                                    </Grid>
                                </Border>

                                <!-- W / K sayilari -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="EloWinsText" FontSize="13" FontWeight="Bold" Foreground="#00D26A"/>
                                    <TextBlock Grid.Column="1" Text="/" FontSize="11" Foreground="#444444" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="EloLossesText" FontSize="13" FontWeight="Bold" Foreground="#FF4655"/>
                                </Grid>

                                <!-- W / K kutucuklar -->
                                <ItemsControl ItemsSource="{Binding MmrMacListesi}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" CornerRadius="3" Margin="1.5,1.5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2A1A1A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Kazandi}" Value="True">
                                                                <Setter Property="Background" Value="#1A2A1A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="8" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="K"/>
                                                            <Setter Property="Foreground" Value="#FF4655"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kazandi}" Value="True">
                                                                    <Setter Property="Text" Value="W"/>
                                                                    <Setter Property="Foreground" Value="#00D26A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ AKTIVITE BOLUMU ═══ -->
                <Grid Margin="0,32,0,16">
                    <TextBlock Text="Aktivite" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </Grid>

                <!-- UST: Saatlik + Haftalik yan yana -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SOL: Saatlik -->
                    <Border Grid.Column="0" Background="#141414" BorderBrush="#222222"
                            BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <!-- Baslik satiri -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SaatlikOzet.OrtalamaGunlukMac, StringFormat={}{0:F1}}"
                                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,3,0,0">
                                            <TextBlock Text="▼" FontSize="10" Foreground="#FF4655"/>
                                            <TextBlock Text="{Binding SaatlikOzet.GunlukDegisim, StringFormat={}{0:F1}}"
                                                       FontSize="10" Foreground="#FF4655" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Ortalama gunluk maclar" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Ellipse Width="7" Height="7" Fill="#00D26A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Galibiyetler" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Oynanan Maclar" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <!-- Grafik canvas -->
                            <Canvas x:Name="SaatlikCanvas" Height="90" Background="Transparent"
                                    SizeChanged="SaatlikCanvas_SizeChanged"
                                    MouseMove="SaatlikCanvas_MouseMove" MouseLeave="SaatlikCanvas_MouseLeave"/>
                            <!-- X ekseni: 0, 6, 12, 18, 24 -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="0" FontSize="9" Foreground="#444444"/>
                                <TextBlock Grid.Column="1" Text="6" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="12" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="18" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="24" FontSize="9" Foreground="#444444"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- SAG: Haftalik -->
                    <Border Grid.Column="2" Background="#141414" BorderBrush="#222222"
                            BorderThickness="1" CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <!-- Baslik satiri -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding HaftalikOzet.OrtalamaHaftalikMac, StringFormat={}{0:F1}}"
                                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,3,0,0">
                                            <TextBlock Text="▼" FontSize="10" Foreground="#FF4655"/>
                                            <TextBlock Text="{Binding HaftalikOzet.HaftalikDegisim, StringFormat={}{0:F1}}"
                                                       FontSize="10" Foreground="#FF4655" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Ortalama haftalik maclar" FontSize="10" Foreground="#555555" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Ellipse Width="7" Height="7" Fill="#00D26A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Galibiyetler" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Oynanan Maclar" FontSize="9" Foreground="#555555"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <!-- Grafik canvas -->
                            <Canvas x:Name="HaftalikCanvas" Height="90" Background="Transparent"
                                    SizeChanged="HaftalikCanvas_SizeChanged"
                                    MouseMove="HaftalikCanvas_MouseMove" MouseLeave="HaftalikCanvas_MouseLeave"/>
                            <!-- X ekseni: gun adlari -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pzt" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Sal" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Car" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Per" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Cum" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Cmt" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Paz" FontSize="9" Foreground="#444444" HorizontalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ALT: Aktivite Takvimi (GitHub tarzı) -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                        CornerRadius="12" Padding="16,14" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Ay baslik satiri -->
                        <Canvas x:Name="TakvimAyCanvas" Height="16" Background="Transparent"
                                SizeChanged="TakvimAyCanvas_SizeChanged" Margin="32,0,0,2"/>

                        <!-- Gun adlari + Hucre grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sol: Gun adlari (P S C P C C P) -->
                            <StackPanel Grid.Column="0" Margin="0,1,0,0">
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="S"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="C"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                                <TextBlock Text="P"  FontSize="9" Foreground="#444444" Height="12" Margin="0,1"/>
                            </StackPanel>

                            <!-- Sag: Hucre grid (Canvas ile cizilecek) -->
                            <Canvas Grid.Column="1" x:Name="TakvimCanvas" Height="112"
                                    Background="Transparent" SizeChanged="TakvimCanvas_SizeChanged"
                                    MouseMove="TakvimCanvas_MouseMove" MouseLeave="TakvimCanvas_MouseLeave"/>
                        </Grid>

                        <!-- Aciklama satiri -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Oynanan Oyunlar" FontSize="10" Foreground="#444444"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#3D1A5C" Margin="0,0,4,0"/>
                            <TextBlock Text="Dusuk" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#7B2FBE" Margin="0,0,4,0"/>
                            <TextBlock Text="Orta" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#C840E9" Margin="0,0,4,0"/>
                            <TextBlock Text="Yuksek" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#FF2D9B" Margin="0,0,4,0"/>
                            <TextBlock Text="Fusya" FontSize="9" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Width="11" Height="11" CornerRadius="2" Background="#252525" Margin="0,0,4,0"/>
                            <TextBlock Text="Oyun Yok" FontSize="9" Foreground="#555555" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                </StackPanel>

                <!-- MAC GECMISI TAB -->
                <StackPanel x:Name="IcerikMacGecmisi" Visibility="{Binding TabMacGecmisi, Converter={StaticResource BoolToVis}}">

                    <!-- Header satiri (kutucuksuz, sadece kalin yazi) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="2*" MinWidth="140"/>
                            <ColumnDefinition Width="*" MinWidth="70"/>
                            <ColumnDefinition Width="*" MinWidth="80"/>
                            <ColumnDefinition Width="*" MinWidth="55"/>
                            <ColumnDefinition Width="*" MinWidth="50"/>
                            <ColumnDefinition Width="2*" MinWidth="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="TARİH" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="PUAN" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="DEĞERLENDİRME" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="K/D/A" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="K/D" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="ADR" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="HARİTA" FontSize="11" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Ayrac cizgisi -->
                    <Rectangle Height="1" Fill="#1A1A1A" Margin="0,0,0,6"/>

                    <!-- Scrollable liste -->
<ScrollViewer x:Name="MacGecmisiScroll" MaxHeight="520"
                              ScrollChanged="MacGecmisiScroll_ScrollChanged"
                              VerticalScrollBarVisibility="Hidden"
                              Background="Transparent" BorderThickness="0">
                        <ItemsControl ItemsSource="{Binding MacGecmisiListesi}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                            CornerRadius="6" Margin="0,0,0,6" Height="52"
                                            Loaded="MacGecmisiRow_Loaded" Padding="0"
                                             MouseEnter="MacSatir_MouseEnter" MouseLeave="MacSatir_MouseLeave"
                                             MouseDown="MacSatir_Tikla">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="2*" MinWidth="140"/>
                                                <ColumnDefinition Width="*" MinWidth="70"/>
                                                <ColumnDefinition Width="*" MinWidth="80"/>
                                                <ColumnDefinition Width="*" MinWidth="55"/>
                                                <ColumnDefinition Width="*" MinWidth="50"/>
                                                <ColumnDefinition Width="2*" MinWidth="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Sol kenar cizgisi -->
                                            <Rectangle Grid.ColumnSpan="9"
                                                       Width="3" Height="36"
                                                       Fill="{Binding Kazandi, Converter={StaticResource MacSonucRenkConv}}"
                                                       Margin="4,8,0,8"
                                                       HorizontalAlignment="Left"
                                                       RadiusX="1" RadiusY="1"/>

                                            <!-- Tarih -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding TarihUst}" FontSize="10"
                                                           Foreground="#CCCCCC" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding TarihAlt}" FontSize="9"
                                                           Foreground="#777777" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <!-- Puan: W/K badge + skor -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Margin="4,0">
                                                <Border Width="20" Height="20" CornerRadius="4"
                                                        Background="{Binding Kazandi, Converter={StaticResource MacSonucBgConv}}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SkorKutucukText}"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <TextBlock Text="{Binding SkorBizim, Mode=OneWay}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{Binding SkorBizimRenk}"/>
                                                    <TextBlock Text=" : " FontSize="11" Foreground="#555555" Margin="1,0"/>
                                                    <TextBlock Text="{Binding SkorOnlar, Mode=OneWay}" FontSize="11"
                                                               Foreground="{Binding SkorOnlarRenk}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Orta alan: Mod + ELO + RR -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal" Margin="4,0">
                                                <TextBlock Text="{Binding ModText}" FontSize="11"
                                                           Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding EloText, StringFormat=' • {0}'}"
                                                           FontSize="11" Foreground="#CCCCCC"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding EloVisible, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0"
                                                            Visibility="{Binding RrVisible, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="▲" FontSize="8" Foreground="#00D26A"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding RrPozitif, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="▼" FontSize="8" Foreground="#FF4655"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding RrNegatif, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding RrText}" FontSize="11"
                                                               Foreground="{Binding Kazandi, Converter={StaticResource MacSonucRenkConv}}"
                                                               VerticalAlignment="Center" Margin="2,0,0,0"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Degerlendirme: renkli KD kutucugu -->
                                            <Border Grid.Column="4" Width="64" Height="26" CornerRadius="4"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Background="{Binding KdOran, Converter={StaticResource KdRenkConv}}">
                                                <TextBlock Text="{Binding KdText}" FontSize="12" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- K/D/A -->
                                            <TextBlock Grid.Column="5" Text="{Binding KdaText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- K/D -->
                                            <TextBlock Grid.Column="6" Text="{Binding KdText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- ADR -->
                                            <TextBlock Grid.Column="7" Text="{Binding AdrText}" FontSize="12"
                                                       Foreground="White" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" FontWeight="Medium"/>

                                            <!-- Harita -->
                                            <StackPanel Grid.Column="8" VerticalAlignment="Center" Margin="6,0,12,0">
                                                <TextBlock Text="{Binding HaritaAdi}" FontSize="12"
                                                           Foreground="#CCCCCC" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding AjanAdi}" FontSize="10"
                                                           Foreground="#777777" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Yukleniyor daha fazla -->
                    <StackPanel Visibility="{Binding IsLoadingMore, Converter={StaticResource BoolToVis}}"
                                Margin="0,4,0,0" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Height="2" Width="120"
                                     Background="#252525" Foreground="#555555"/>
                        <TextBlock Text="Daha fazla yükleniyor..." FontSize="10" Foreground="#555555"
                                   Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- CANLI MAC TAB -->
                <StackPanel x:Name="IcerikCanliMac" Visibility="{Binding TabCanliMac, Converter={StaticResource BoolToVis}}">

                    <!-- BEKLENIYOR -->
                    <StackPanel Visibility="{Binding CanliMacWaiting, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" Margin="0,60,0,0">
                        <Ellipse Width="10" Height="10" Fill="#555555" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Maç bekleniyor..." FontSize="13" Foreground="#555555"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Riot istemcisi açık ancak henüz bir maçta değilsin." FontSize="10"
                                   Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="Bir maça girince otomatik olarak görünecek." FontSize="10"
                                   Foreground="#333333" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- HATA: Riot kapali -->
                    <StackPanel Visibility="{Binding CanliMacError, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" Margin="0,60,0,0">
                        <TextBlock Text="Riot İstemcisi Bulunamadı" FontSize="13" Foreground="#888888"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Canlı maç takibi için Riot istemcisinin açık olması gerekir."
                                   FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- CANLI MAC ICERIK -->
                    <StackPanel Visibility="{Binding CanliMacVisible, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,24">

                        <!-- ═══ UST BILGI BANNER ═══ -->
                        <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                CornerRadius="10" Padding="16,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Ellipse x:Name="CanliNokta" Width="8" Height="8" Fill="#00D26A"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Canlı Maç" FontSize="14" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#252525" CornerRadius="4"
                                        Padding="8,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CanliMacTypeText}" FontSize="10"
                                               Foreground="#AAAAAA" FontWeight="SemiBold"/>
                                </Border>

                                <Border Grid.Column="2" Background="#252525" CornerRadius="4"
                                        Padding="8,4" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CanliMacMapText}" FontSize="10"
                                                   Foreground="#CCCCCC" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding CanliMacServerText, StringFormat='Sunucu: {0}'}"
                                               FontSize="10" Foreground="#777777" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding CanliMacTimeText}" FontSize="10" Foreground="#777777"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ═══ KAZANMA SANSI BAR ═══ -->
                        <Border Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                CornerRadius="10" Padding="16,12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="TAKIMINIZIN KAZANMA ŞANSI" FontSize="10"
                                           Foreground="#666666" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Height="24">
                                    <!-- Arkaplan -->
                                    <Border CornerRadius="12" Background="#1A1A1A"/>

                                    <!-- Oransal kolonlar -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding WinChanceBiz, Converter={StaticResource StarConv}}"/>
                                            <ColumnDefinition Width="{Binding WinChanceRakip, Converter={StaticResource StarConv}}"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{Binding WinChanceBizRenk}"
                                                CornerRadius="12,0,0,12" Opacity="0.8"/>
                                        <Border Grid.Column="1" Background="{Binding WinChanceRakipRenk}"
                                                CornerRadius="0,12,12,0" Opacity="0.8"/>
                                    </Grid>

                                    <!-- Yuzde yazilari (ustte) -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WinChanceBiz, StringFormat='{}{0:F0}% Takımınız'}"
                                                   FontSize="11" FontWeight="Bold" Foreground="White"
                                                   Margin="0,0,16,0"/>
                                        <TextBlock Text="{Binding WinChanceRakip, StringFormat='Rakip %{0:F0}'}"
                                                   FontSize="11" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══ TAKIM KARTLARI ═══ -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SOL: TAKIMIMIZ -->
                            <StackPanel Grid.Column="0" x:Name="BenimTakimPanel">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="TAKIMINIZ" FontSize="11" FontWeight="Bold"
                                               Foreground="#00D26A" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CanliMacOyuncularim.Count, StringFormat=' ({0})'}"
                                               FontSize="10" Foreground="#555555" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding CanliMacOyuncularim}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="OyuncuKart" Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                                    CornerRadius="8" Padding="10,6" Margin="0,0,0,6" Height="56">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Profil Fotografi -->
                                                    <Border Width="36" Height="36" CornerRadius="18"
                                                            Background="#2A2A2A" ClipToBounds="True">
                                                        <Image Source="{Binding PlayerCardUrl}"
                                                               Width="36" Height="36" Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>

                                                    <!-- Bilgiler -->
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="White"/>
                                                            <TextBlock Text="{Binding Tag, StringFormat='#{}'}"
                                                                       FontSize="11" Foreground="#666666" Margin="4,0,0,0"/>
                                                            <Border Background="#2A3A2A" CornerRadius="3" Padding="4,1" Margin="6,0,0,0">
                                                                <TextBlock Text="{Binding Agent}" FontSize="8"
                                                                           Foreground="#66BB6A" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <Image Source="{Binding RankIkonFromTierKaynak}"
                                                                   Width="14" Height="14" VerticalAlignment="Center"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="{Binding Rank}" FontSize="10"
                                                                       Foreground="#AAAAAA" FontWeight="SemiBold"
                                                                       Margin="4,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Elo, StringFormat='• {0} ELO'}"
                                                                       FontSize="10" Foreground="#666666" VerticalAlignment="Center"/>
                                                            <TextBlock Text="|" FontSize="10" Foreground="#333333"
                                                                       Margin="6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="K/D/A" FontSize="9" Foreground="#555555"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding KdaText}" FontSize="10"
                                                                       Foreground="#CCCCCC" FontWeight="SemiBold"
                                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                            <!-- Son 4 maç W/L kareleri -->
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="4,0,1,0"
                                                                    Background="{Binding Match1Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0"
                                                                    Background="{Binding Match2Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0"
                                                                    Background="{Binding Match3Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0,0,0"
                                                                    Background="{Binding Match4Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- AYIRAC -->
                            <Border Grid.Column="1" Background="#222222" Width="1" Margin="0,28,0,0"/>

                            <!-- SAG: RAKIP TAKIM -->
                            <StackPanel Grid.Column="2" x:Name="RakipTakimPanel">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="RAKİP TAKIM" FontSize="11" FontWeight="Bold"
                                               Foreground="#FF4655" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CanliMacRakipler.Count, StringFormat=' ({0})'}"
                                               FontSize="10" Foreground="#555555" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding CanliMacRakipler}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="OyuncuKart" Background="#141414" BorderBrush="#222222" BorderThickness="1"
                                                    CornerRadius="8" Padding="10,6" Margin="0,0,0,6" Height="56">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Profil Fotografi -->
                                                    <Border Width="36" Height="36" CornerRadius="18"
                                                            Background="#2A2A2A" ClipToBounds="True">
                                                        <Image Source="{Binding PlayerCardUrl}"
                                                               Width="36" Height="36" Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>

                                                    <!-- Bilgiler -->
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="White"/>
                                                            <TextBlock Text="{Binding Tag, StringFormat='#{}'}"
                                                                       FontSize="11" Foreground="#666666" Margin="4,0,0,0"/>
                                                            <Border Background="#2A3A2A" CornerRadius="3" Padding="4,1" Margin="6,0,0,0">
                                                                <TextBlock Text="{Binding Agent}" FontSize="8"
                                                                           Foreground="#66BB6A" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <Image Source="{Binding RankIkonFromTierKaynak}"
                                                                   Width="14" Height="14" VerticalAlignment="Center"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="{Binding Rank}" FontSize="10"
                                                                       Foreground="#AAAAAA" FontWeight="SemiBold"
                                                                       Margin="4,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Elo, StringFormat='• {0} ELO'}"
                                                                       FontSize="10" Foreground="#666666" VerticalAlignment="Center"/>
                                                            <TextBlock Text="|" FontSize="10" Foreground="#333333"
                                                                       Margin="6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="K/D/A" FontSize="9" Foreground="#555555"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding KdaText}" FontSize="10"
                                                                       Foreground="#CCCCCC" FontWeight="SemiBold"
                                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                            <!-- Son 4 maç W/L kareleri -->
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="4,0,1,0"
                                                                    Background="{Binding Match1Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0"
                                                                    Background="{Binding Match2Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0"
                                                                    Background="{Binding Match3Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                            <Border Width="8" Height="8" CornerRadius="2" Margin="1,0,0,0"
                                                                    Background="{Binding Match4Win, Converter={StaticResource MacSonucBgConv}}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </StackPanel>

        <!-- ═══ MAÇ DETAY TAM SAYFA ═══ -->
        <Border x:Name="MacDetayBackdrop" Visibility="Collapsed"
                Background="#0D0D0D"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                IsHitTestVisible="True">
            <ScrollViewer x:Name="MacDetayScroll" VerticalScrollBarVisibility="Hidden"
                          CanContentScroll="False" Background="Transparent"
                          Padding="20,0,20,4"
                          Focusable="True">
                <StackPanel>

                    <!-- Yukleniyor -->
                    <StackPanel Visibility="{Binding MacDetayYukleniyor, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" Margin="0,120,0,0">
                        <TextBlock Text="Maç detayı yükleniyor..." FontSize="12" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <ProgressBar IsIndeterminate="True" Height="2" Width="120"
                                     Background="#252525" Foreground="#555555"/>
                    </StackPanel>

                    <!-- Hata -->
                    <StackPanel Visibility="{Binding MacDetayHata, Converter={StaticResource StrToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,120,0,0">
                        <TextBlock Text="Maç detayı yüklenemedi" FontSize="14" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding MacDetayHata}" FontSize="12" Foreground="#FFAAAA"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="400"/>
                    </StackPanel>

                    <!-- Icerik -->
                    <StackPanel Visibility="{Binding MacDetayVisible, Converter={StaticResource BoolToVis}}">

                        <!-- GERI -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" Cursor="Hand"
                                    PreviewMouseLeftButtonDown="MacDetayGeri_Tikla">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1A1A1A"
                                    BorderBrush="#252525" BorderThickness="1">
                                <TextBlock Text="←" FontSize="16" Foreground="#888888"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Geri" FontSize="13" Foreground="#888888"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- ══════════════════════════════════════════════════════ -->
                        <!-- ÜST PANEL — MVP KARTI + MAÇ LİDERLERİ               -->
                        <!-- ══════════════════════════════════════════════════════ -->
                        <Grid Margin="0,16,0,0" x:Name="UstPanelGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ═══════ SOL: MVP KARTI ═══════ -->
                            <Border Grid.Column="0" Background="#11141a" CornerRadius="8" Padding="16"
                                    x:Name="MvpKarti" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="MvpKartiSlide" X="-30"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profil Alt Kartı -->
                                    <Border Grid.Column="0" Background="#08090c" CornerRadius="6" Padding="14,18"
                                            Width="150" VerticalAlignment="Stretch">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Border Width="60" Height="60" CornerRadius="30"
                                                    BorderBrush="#19FFFFFF" BorderThickness="2">
                                                <Image Source="{Binding SeciliMacDetay.Ben.AjanUrl}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding SeciliMacDetay.Ben.Ad}" FontSize="16"
                                                       FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" Margin="0,10,0,2"/>
                                            <TextBlock Text="{Binding SeciliMacDetay.Ben.Tag, StringFormat='{}#{0}'}"
                                                       FontSize="11" Foreground="#666666"
                                                       HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
