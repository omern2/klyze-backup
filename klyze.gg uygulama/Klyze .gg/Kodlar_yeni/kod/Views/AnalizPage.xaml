                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Edge indicator -->
                                                <Border Grid.Column="38" Width="12" Height="24"
                                                        CornerRadius="3" Background="{Binding EdgeRenk}"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ══════════════════════════════════════════════════════ -->
                        <!-- RAKIPLER                                             -->
                        <!-- ══════════════════════════════════════════════════════ -->
                        <StackPanel Margin="0,0,0,0">
                            <!-- Section header -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rakipler" FontSize="16"
                                           FontWeight="SemiBold" Foreground="White"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Takım Ort." FontSize="10" Foreground="#666666"
                                               VerticalAlignment="Center"/>
                                    <Image Source="{Binding SeciliMacDetay.RakipOrtRankIkon}" Width="16" Height="16"
                                           Margin="4,0,2,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SeciliMacDetay.RakipOrtElo}" FontSize="10"
                                               Foreground="#AAAAAA" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Column headers -->

                            <!-- Column headers -->
                            <Grid Height="18" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="2"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="2"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="2"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="4" Text="OYUNCU" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="SIRA" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="SKOR" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="10" Text="SWING" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="12" Text="K" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="14" Text="D" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="16" Text="A" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="18" Text="ADR" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="20" Text="K/D" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="22" Text="K/R" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="24" Text="HS" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="26" Text="HS%" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="28" Text="5" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="30" Text="4" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="32" Text="3" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="34" Text="2" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="36" Text="EDO" FontSize="9" FontWeight="Bold"
                                           Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Data rows -->
                            <ItemsControl x:Name="RakipItems" ItemsSource="{Binding SeciliMacDetay.Rakipler}" VirtualizingPanel.IsVirtualizing="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="RakipSatir" Height="40" Background="#11141a"
                                                BorderBrush="#08FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,3" CornerRadius="4">
                                            <Grid Height="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="46"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="34"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Team indicator: red -->
                                                <Border Grid.Column="0" Background="#FF4655"/>

                                                <!-- Avatar -->
                                                <Ellipse Grid.Column="2" Width="22" Height="22"
                                                         Stroke="#19FFFFFF" StrokeThickness="1"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding KartUrl}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <!-- Player name + tag + agent -->
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Ad}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="White"/>
                                                        <TextBlock Text="{Binding Tag, StringFormat='{}#{0}'}"
                                                                   FontSize="9" Foreground="#555555"
                                                                   Margin="3,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding AjanAdi}" FontSize="9"
                                                               Foreground="#555555" FontStyle="Italic"/>
                                                </StackPanel>

                                                <!-- Rank emblem + MMR -->
                                                <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Image Source="{Binding RankIkonKaynak}" Width="20" Height="20"
                                                           VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding KdText, StringFormat='{}{0}'}"
                                                               FontSize="9" Foreground="#888888" FontWeight="Medium"
                                                               Margin="3,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Evaluation box (54x28px) -->
                                                <Grid Grid.Column="8" Width="54" Height="28"
                                                       VerticalAlignment="Center">
                                                    <Border Background="#1A1A1A" CornerRadius="4"/>
                                                    <Border Width="{Binding DegerlendirmeBarGenislik}"
                                                            CornerRadius="4" HorizontalAlignment="Left"
                                                            Background="{Binding DegerlendirmeRenk}"/>
                                                    <Border Background="#00000000" CornerRadius="4"
                                                            BorderBrush="#0FFFFFFF" BorderThickness="1"/>
                                                    <TextBlock Text="{Binding DegerlendirmeText}" FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding DegerlendirmeTextRenk}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>

                                                <!-- MVP star -->
                                                <TextBlock Grid.Column="8" Text="★" FontSize="12"
                                                           Foreground="#FFD700"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Top"
                                                           Margin="0,-2,-2,0"
                                                           Visibility="{Binding IsMvp, Converter={StaticResource BoolToVis}}"/>

                                                <!-- Swing % -->
                                                <TextBlock Grid.Column="10" Text="{Binding SwingText}" FontSize="10"
                                                           Foreground="{Binding SwingRenk}" FontWeight="Medium"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- K -->
                                                <TextBlock Grid.Column="12" Text="{Binding Kills}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="#EEEEEE"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- D -->
                                                <TextBlock Grid.Column="14" Text="{Binding Deaths}" FontSize="11"
                                                           Foreground="#999999"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- A -->
                                                <TextBlock Grid.Column="16" Text="{Binding Assists}" FontSize="11"
                                                           Foreground="#777777"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- ADR -->
                                                <TextBlock Grid.Column="18" Text="{Binding AdrText}" FontSize="10"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- K/D -->
                                                <TextBlock Grid.Column="20" Text="{Binding KdText}" FontSize="10"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- K/R -->
                                                <TextBlock Grid.Column="22" Text="{Binding KrText}" FontSize="10"
                                                           Foreground="#CCCCCC"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- HS -->
                                                <TextBlock Grid.Column="24" Text="{Binding HsText}" FontSize="10"
                                                           Foreground="#BBBBBB"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- HS% -->
                                                <TextBlock Grid.Column="26" Text="{Binding HsYuzdeText}" FontSize="10"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- 5k -->
                                                <TextBlock Grid.Column="28" Text="{Binding Kill5kText}" FontSize="9"
                                                           Foreground="#FFD700"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 4k -->
                                                <TextBlock Grid.Column="30" Text="{Binding Kill4kText}" FontSize="9"
                                                           Foreground="#88DD88"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 3k -->
                                                <TextBlock Grid.Column="32" Text="{Binding Kill3kText}" FontSize="9"
                                                           Foreground="#AAAAAA"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 2k -->
                                                <TextBlock Grid.Column="34" Text="{Binding Kill2kText}" FontSize="9"
                                                           Foreground="#666666"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- EDO'lar -->
                                                <TextBlock Grid.Column="36" Text="{Binding MvpSayisiText}" FontSize="10"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <!-- Edge indicator -->
                                                <Border Grid.Column="38" Width="12" Height="24"
                                                        CornerRadius="3" Background="{Binding EdgeRenk}"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
