<UserControl x:Class="ValorantAutoClicker.Views.AnalizPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:ValorantAutoClicker.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <h:StringToVisibilityConverter x:Key="StrToVis"/>
        <h:PerformansRenkConverter x:Key="PRenkConv"/>
        <h:PerformansGenislikConverter x:Key="PGenislikConv"/>
        <h:PerformansBarConverter x:Key="PBarConv"/>
        <h:WinColorConverter x:Key="MacSonucRenkConv"/>
        <h:BoolToRenkConverter x:Key="MacSonucBgConv"/>
        <h:MacKdRenkConverter x:Key="KdRenkConv"/>
        <h:StarGridLengthConverter x:Key="StarConv"/>

        <Style x:Key="DarkToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Placement" Value="Bottom"/>
            <Setter Property="HorizontalOffset" Value="0"/>
            <Setter Property="VerticalOffset" Value="8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <StackPanel x:Name="AnaStackPanel">

            <!-- YUKLENIYOR -->
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" Margin="0,60,0,0">
                <TextBlock Text="Veriler yukleniyor..." FontSize="12" Foreground="#555555"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ProgressBar IsIndeterminate="True" Height="2" Width="180"
                             Background="#252525" Foreground="#555555"/>
            </StackPanel>

            <!-- HATA -->
            <Border Background="#1A0808" CornerRadius="10" Padding="20,16"
                    BorderBrush="#FF4655" BorderThickness="1"
                    HorizontalAlignment="Center" Margin="0,50,0,0" MaxWidth="380"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Veri yuklenemedi" FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FFAAAA"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,14"/>
                    <Button Content="Tekrar Dene" Height="34" Padding="18,0" Cursor="Hand"
                            Command="{Binding YenileCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#252525" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ANA ICERIK -->
            <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

                <!-- SEKMELER (en üstte) -->
                <Border x:Name="SekmeCubugu" Background="#141414" BorderBrush="#222222"
                        BorderThickness="1" CornerRadius="10" Margin="0,0,0,16"
                        SizeChanged="SekmeCubugu_SizeChanged">
                    <Grid x:Name="SekmeGrid" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TabUnderline" Grid.Column="0"
                                Width="0" Height="2" Background="White"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="0,0,0,6" IsHitTestVisible="False">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="UnderlineTranslate"/>
                            </Border.RenderTransform>
                        </Border>

                        <Button Grid.Column="0" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="0"
                                Background="{Binding TabIstatistikler, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0"
                                            BorderThickness="0"
                                            Background="{TemplateBinding Background}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabIstatistikler}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="İstatistikler" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabIstatistikler}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="1" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0" BorderThickness="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabMacGecmisi}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Maç Geçmişi" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabMacGecmisi}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Height="36" Margin="2,0" Cursor="Hand"
                                Command="{Binding TabCommand}" CommandParameter="2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="0" BorderThickness="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TabCanliMac}" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Canlı Maç" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TabCanliMac}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- DETAY PANELI -->
                <StackPanel x:Name="IcerikIstatistikler" Visibility="{Binding TabIstatistikler, Converter={StaticResource BoolToVis}}">

                <!-- RANK -->
                <TextBlock Text="RANK" FontSize="22" FontWeight="Bold" Foreground="White"
                           Margin="0,0,0,12"/>
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1" CornerRadius="12"
                        Padding="18,16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Rank Iconu -->
                        <Border Grid.Column="0" Width="72" Height="72" CornerRadius="10" Background="#1E1E1E"
                                VerticalAlignment="Center">
                            <Image Source="{Binding RankIkonKaynak}" Width="64" Height="64" Stretch="Uniform"/>
                        </Border>
                        <!-- Orta: Sezon + Tier + RR -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="{Binding SezonKisaAdi}" FontSize="10" Foreground="#666666" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding RutbeTier}" FontSize="20" FontWeight="Bold" Foreground="White"
                                           VerticalAlignment="Center"/>
                                 <TextBlock Text="{Binding ProfilRankAdi, StringFormat={} • {0}}" FontSize="13"
                                           Foreground="#999999" VerticalAlignment="Center" Margin="6,2,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                 <TextBlock Text="{Binding RrDeger, StringFormat={}{0} RR}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding EloRenk}"/>
                                <TextBlock Text="{Binding RrKalanText}" FontSize="10" Foreground="#666666" Margin="8,0,0,0"/>
                            </StackPanel>
                            <!-- RR Progress Bar -->
                            <Grid Height="3" Margin="0,8,20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding RrDeger, Converter={StaticResource StarConv}}"/>
                                    <ColumnDefinition Width="{Binding RrKalan, Converter={StaticResource StarConv}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="2" Background="#FF8C00"/>
                                <Border Grid.Column="1" CornerRadius="2" Background="#252525"/>
                            </Grid>
                        </StackPanel>
                        <!-- ELO Puanı (kutulu) -->
                        <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8"
                                BorderBrush="#FF8C00" BorderThickness="1"
                                VerticalAlignment="Center" HorizontalAlignment="Right" Padding="14,8">
                            <StackPanel>
                                <TextBlock Text="ELO" FontSize="8" FontWeight="Bold" Foreground="#FF8C00"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding MevcutElo, StringFormat={}{0}}" FontSize="22" FontWeight="Bold"
                                           Foreground="#FF8C00" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- BASLIK -->
                <Grid Margin="0,16,0,8">
                    <TextBlock Text="Performans" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="30" Padding="14,0" Cursor="Hand" Command="{Binding YenileCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#1E1E1E" BorderBrush="#2A2A2A"
                                        BorderThickness="1" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="Yenile" FontSize="11" Foreground="#777777"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#252525"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- 3x2 METRIK KARTLARI (2 SATIR 3 KOLON) -->
                <Border Background="#141414" BorderBrush="#222222" BorderThickness="1" CornerRadius="12" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ═══ SATIR 1 ═══ -->

                        <!-- Kazanma Orani [0] -->
                        <Border Grid.Row="0" Grid.Column="0" x:Name="Metrik0"
                                Background="#1E1E1E" CornerRadius="8" Padding="14,14,14,10" Cursor="Hand" BorderThickness="0"
                                ToolTipService.InitialShowDelay="1000"
                                ToolTipService.ShowDuration="60000">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource DarkToolTip}">
                                    <StackPanel Margin="10,8" MinWidth="180">
                                        <TextBlock Text="Kazanma Orani" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KazanmaOraniDetay.Son10MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Son 10" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KazanmaOraniDetay.Son20MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Son 20" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KazanmaOraniDetay.Son50MacOrani, StringFormat={}{0:F1}%}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Son 50" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,6" Height="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding KazanmaOraniDetay.KazanilanMac, Converter={StaticResource StarConv}}"/>
                                                <ColumnDefinition Width="{Binding KazanmaOraniDetay.KaybedilenMac, Converter={StaticResource StarConv}}"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="3" Background="#00D26A" Margin="0,2,1,2"><TextBlock Text="{Binding KazanmaOraniDetay.KazanilanMac}" FontSize="9" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                            <Border Grid.Column="1" CornerRadius="3" Background="#FF4655" Margin="1,2,0,2"><TextBlock Text="{Binding KazanmaOraniDetay.KaybedilenMac}" FontSize="9" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                        </Grid>
                                        <Separator Background="#2A2A2A" Margin="0,2"/>
                                        <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="#666666">
                                            <Run Text="En cok kazanilan: "/><Run Text="{Binding KazanmaOraniDetay.EnCokKazanilanHarita}" Foreground="#00D26A" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="#666666">
                                            <Run Text="En cok kaybedilen: "/><Run Text="{Binding KazanmaOraniDetay.EnCokKaybedilenHarita}" Foreground="#FF4655" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding PerformansMetrikleri[0].DegerText}"
                                               FontSize="24" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,4,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[0].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[0].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[0].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[0].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[0].Adi}"
                                           FontSize="10" Foreground="#777777" Margin="0,0,0,8"/>
                                <Grid Height="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" x:Name="Metrik0Seg0" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="2" x:Name="Metrik0Seg1" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="4" x:Name="Metrik0Seg2" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="6" x:Name="Metrik0Seg3" Background="#252525" CornerRadius="2"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ADR [1] -->
                        <Border Grid.Row="0" Grid.Column="2" x:Name="Metrik1"
                                Background="#1E1E1E" CornerRadius="8" Padding="14,14,14,10" Cursor="Hand" BorderThickness="0"
                                ToolTipService.InitialShowDelay="1000"
                                ToolTipService.ShowDuration="60000">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource DarkToolTip}">
                                    <StackPanel Margin="10,8" MinWidth="180">
                                        <TextBlock Text="ADR" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AdrDetay.EnYuksekAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="En Yuksek" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AdrDetay.OrtalamaAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="#FF8C00" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Ortalama" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AdrDetay.EnDusukAdr, StringFormat={}{0:F0}}" FontSize="18" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                                <TextBlock Text="En Dusuk" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Background="#2A2A2A" Margin="0,2"/>
                                        <ItemsControl ItemsSource="{Binding AdrDetay.HaritaAdrListe}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding HaritaAdi}" FontSize="9" Foreground="#888888"/>
                                                        <Border Grid.Column="1" Height="3" CornerRadius="1" Background="#252525" Margin="4,2">
                                                            <Border CornerRadius="1" HorizontalAlignment="Left" Background="#FF8C00" Width="{Binding Adr, Converter={StaticResource PBarConv}, ConverterParameter=200}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding Adr, StringFormat={}{0:F0}}" FontSize="9" Foreground="#CCCCCC" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding PerformansMetrikleri[1].DegerText}"
                                               FontSize="24" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="6,4,0,0">
                                        <TextBlock Text="{Binding PerformansMetrikleri[1].DegisimOk}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[1].DegisimRenk}"/>
                                        <TextBlock Text="{Binding PerformansMetrikleri[1].DegisimText}"
                                                   FontSize="10" Foreground="{Binding PerformansMetrikleri[1].DegisimRenk}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding PerformansMetrikleri[1].Adi}"
                                           FontSize="10" Foreground="#777777" Margin="0,0,0,8"/>
                                <Grid Height="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" x:Name="Metrik1Seg0" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="2" x:Name="Metrik1Seg1" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="4" x:Name="Metrik1Seg2" Background="#252525" CornerRadius="2"/>
                                    <Border Grid.Column="6" x:Name="Metrik1Seg3" Background="#252525" CornerRadius="2"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- K/D [2] -->
                        <Border Grid.Row="0" Grid.Column="4" x:Name="Metrik2"
                                Background="#1E1E1E" CornerRadius="8" Padding="14,14,14,10" Cursor="Hand" BorderThickness="0"
                                ToolTipService.InitialShowDelay="1000"
                                ToolTipService.ShowDuration="60000">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource DarkToolTip}">
                                    <StackPanel Margin="10,8" MinWidth="180">
                                        <TextBlock Text="K/D" FontSize="13" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KrDetay.ToplamKill}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Kill" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KrDetay.ToplamDeath}" FontSize="18" FontWeight="Bold" Foreground="#FF4655" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Death" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KrDetay.ToplamAsist}" FontSize="18" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Asist" FontSize="9" Foreground="#777777" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,4" Height="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding KrDetay.ToplamKill, Converter={StaticResource StarConv}}"/>
                                                <ColumnDefinition Width="{Binding KrDetay.ToplamDeath, Converter={StaticResource StarConv}}"/>
                                                <ColumnDefinition Width="{Binding KrDetay.ToplamAsist, Converter={StaticResource StarConv}}"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2ECC71" Margin="0,2,1,2" CornerRadius="2"><TextBlock Text="K" FontSize="8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                            <Border Grid.Column="1" Background="#FF4655" Margin="1,2,1,2" CornerRadius="2"><TextBlock Text="D" FontSize="8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
