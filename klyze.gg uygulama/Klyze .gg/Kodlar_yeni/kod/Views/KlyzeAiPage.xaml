<UserControl x:Class="ValorantAutoClicker.Views.KlyzeAiPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Token bar -->
        <Border Grid.Row="0" Background="#141414" CornerRadius="10" Padding="20,14" Margin="0,0,0,12"
                BorderBrush="#2A2A2A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#2A2A2A">
                    <TextBlock Text="AI" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Klyze AI" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Valorant Asistanı" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <Border Grid.Column="2" Background="#1A2E1A" CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                        BorderBrush="#2ECC7133" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Token: " FontSize="11" Foreground="#2ECC71" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding KalanToken}" FontSize="11" FontWeight="Bold" Foreground="#2ECC71" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="SohbetScroll" VerticalScrollBarVisibility="Auto"
                      PanningMode="VerticalOnly" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding Mesajlar}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" MaxWidth="85%" Padding="14,10"
                                CornerRadius="10" BorderThickness="1" Background="#1E1E1E" BorderBrush="#2A2A2A">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding KullaniciMesaji}" Value="True">
                                            <Setter Property="Background" Value="#2A2A5A"/>
                                            <Setter Property="BorderBrush" Value="#3A3A7A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Icerik}" FontSize="13" Foreground="White"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input -->
        <Border Grid.Row="2" Background="#141414" CornerRadius="10" Padding="12,10"
                BorderBrush="#2A2A2A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="4"
                        BorderBrush="#3A3A3A" BorderThickness="1" Margin="0,0,8,0">
                    <TextBox Text="{Binding GirisMetni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Foreground="White" Background="Transparent" BorderThickness="0"
                             Padding="10,8" CaretBrush="White" AcceptsReturn="False"
                             KeyDown="GirisKutusu_KeyDown"/>
                </Border>

                <Button Grid.Column="1" Width="44" Height="38" Margin="0,0,6,0"
                        Background="#2A2A2A" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding GonderCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    ➤
                </Button>

                <Button Grid.Column="2" Width="38" Height="38"
                        Background="#252525" Foreground="#888" FontSize="14"
                        BorderThickness="1" BorderBrush="#3A3A3A" Cursor="Hand"
                        Command="{Binding SohbetiTemizleCommand}"
                        ToolTip="Sohbeti temizle">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#303030"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    ✕
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
