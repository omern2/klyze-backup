<UserControl x:Class="ValorantAutoClicker.Views.PlayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:ValorantAutoClicker.Helpers"
             Loaded="Page_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <h:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <h:StringToVisibilityConverter x:Key="StrToVis"/>

        <ControlTemplate x:Key="DarkBtnTemplate" TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                            </ScrollViewer>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,8,0,32">

                <!-- ═══════════════ OYUNCU KARTI ═══════════════ -->
                <Border x:Name="OyuncuKarti"
                        Background="#CC141414"
                        BorderBrush="#333333"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24,22"
                        Margin="0,0,0,20"
                        RenderTransformOrigin="0.5,0.5"
                        Opacity="0">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="KartScale" ScaleX="0.8" ScaleY="0.8"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                Width="80" Height="80"
                                CornerRadius="40"
                                Background="#1E1E1E"
                                BorderBrush="#2A2A2A"
                                BorderThickness="2"
                                Margin="0,0,20,0"
                                ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding CardImageSource}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock x:Name="AvatarHarf"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#444444"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <!-- Bilgi -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OyuncuAdi}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding OyuncuTag, StringFormat='#{0}'}"
                                       FontSize="12"
                                       Foreground="#555555"
                                       Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding RankIkonKaynak}"
                                       Width="22" Height="22"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding RutbeAdi}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <Border Background="#1E1E1E" CornerRadius="6" Padding="8,3">
                                    <TextBlock Text="{Binding EloText, StringFormat='{}{0} ELO'}"
                                               FontSize="11"
                                               Foreground="#888888"
                                               FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════ MAÇ BUL BUTONU ═══════════════ -->
                <Grid x:Name="MacBulGrid" Margin="0,0,0,16" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="MacBulTranslate" Y="24"/>
                    </Grid.RenderTransform>

                    <Button x:Name="MacBulBtn"
                            Height="54"
                            Cursor="Hand"
                            Background="#1E1E1E"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            Command="{Binding MacBulCommand}"
                            Template="{StaticResource DarkBtnTemplate}">
                        <TextBlock Text="MAÇ BUL"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </Button>

                    <!-- + Badge (sağ üst) -->
                    <Button x:Name="PlusBtn"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-8,-8,0"
                            Cursor="Hand"
                            Background="#252525"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            Command="{Binding LobiOlusturAcCommand}"
                            ToolTip="Lobi Oluştur">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="14"
                                        Width="28"
                                        Height="28">
                                    <TextBlock Text="+"
                                               FontSize="16"
                                               FontWeight="Light"
                                               Foreground="#AAAAAA"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#333333"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#666666"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══════════════ MAÇ SEÇENEKLERİ ═══════════════ -->
                <Border x:Name="SecenekGrid"
                        Opacity="0"
                        Background="#141414"
                        BorderBrush="White"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,14"
                        Margin="0,0,0,20">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="SecenekTranslate" X="-20"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Standart Maç"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Dereceli · 5v5"
                                       FontSize="11"
                                       Foreground="#555555"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#252525"
                                CornerRadius="6"
                                Padding="8,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="Seçili"
                                       FontSize="10"
                                       Foreground="#888888"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════════════ HATA MESAJI ═══════════════ -->
                <Border Background="#1A0808"
                        CornerRadius="10"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        BorderBrush="#FF4655"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="12"
                               Foreground="#FFAAAA"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- ═══════════════ ARAMA PANELİ ═══════════════ -->
                <Border x:Name="AramaPaneli"
                        Background="#141414"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="48" Height="48" Stroke="#252525" StrokeThickness="4"/>
                            <Border Width="48" Height="48" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRot" Angle="0"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRot"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Ellipse Width="48" Height="48" Stroke="White" StrokeThickness="4"
                                         StrokeDashArray="10 40"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Uygun lobiler aranıyor..."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ BULUNAN LOBİ KARTI ═══════════════ -->
                <Border x:Name="LobiKarti"
                        Background="#141414"
                        BorderBrush="#333333"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="22,18"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="LobiKartiScale" ScaleX="0.92" ScaleY="0.92"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Background="#1E2A1E" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock Text="Lobi Bulundu" FontSize="11" Foreground="#00D26A" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding BulunanLobi.HostName}"
                                       FontSize="11"
                                       Foreground="#555555"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding BulunanLobi.GroupCode}"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Valorant Grup Kodu"
                                   FontSize="11"
                                   Foreground="#444444"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                            <Image Source="{Binding BulunanLobiRankIkon}"
                                   Width="18" Height="18"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BulunanLobi.HostElo, Mode=OneWay}"
                                           FontSize="12" Foreground="#888888"/>
                                <TextBlock Text=" ELO" FontSize="12" Foreground="#888888"/>
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="KopyalaBtn"
                                Height="44"
                                Cursor="Hand"
                                Command="{Binding KoduKopyalaCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Padding="0,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1E1E1E"/>
                                    <Setter Property="BorderBrush" Value="#333333"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kopyalandi}" Value="True">
                                            <Setter Property="Background" Value="#1A2A1A"/>
                                            <Setter Property="BorderBrush" Value="#00D26A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="{Binding KopyalaButonText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kopyalandi}" Value="True">
                                                <Setter Property="Foreground" Value="#00D26A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>

                        <Button Height="36"
                                Cursor="Hand"
                                Margin="0,8,0,0"
                                Command="{Binding SifirlaCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="Geri Dön" FontSize="12" Foreground="#555555"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ LOBİ YOK ═══════════════ -->
                <Border x:Name="LobiYokPaneli"
                        Background="#141414"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Uygun lobi bulunamadı"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Lobi oluşturabilirsin"
                                   FontSize="12"
                                   Foreground="#555555"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"/>
                        <Button Height="42"
                                Padding="24,0"
                                Cursor="Hand"
                                Command="{Binding LobiOlusturAcCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="#1E1E1E"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <TextBlock Text="+ Lobi Oluştur" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                        </Button>
                        <Button Height="36"
                                Cursor="Hand"
                                Margin="0,8,0,0"
                                Command="{Binding SifirlaCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="Geri Dön" FontSize="12" Foreground="#555555"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ LOBİ OLUŞTURULDU ═══════════════ -->
                <Border x:Name="LobiOlusturulduPaneli"
                        Background="#141414"
                        BorderBrush="#1A3A1A"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="22,18"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1E2A1E" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock Text="Lobi Aktif" FontSize="11" Foreground="#00D26A" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding AktifGrupKodu}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Grup Kodun"
                                   FontSize="11"
                                   Foreground="#444444"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>
                        <TextBlock Text="Lobi oluşturuldu, maç bekleniyor..."
                                   FontSize="12"
                                   Foreground="#555555"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <Button Height="38"
                                Padding="20,0"
                                Cursor="Hand"
                                Command="{Binding SifirlaCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="#1E1E1E"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <TextBlock Text="Lobiyi Kapat" FontSize="12" Foreground="#888888"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ EŞLEŞME ARANIYOR ═══════════════ -->
                <Border x:Name="EslesmePaneli"
                        Background="#141414"
                        BorderBrush="#222222"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Ellipse Width="48" Height="48" Stroke="#252525" StrokeThickness="4"/>
                            <Border Width="48" Height="48" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="EslesmeSpinnerRot" Angle="0"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="EslesmeSpinnerRot"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Ellipse Width="48" Height="48" Stroke="#00D26A" StrokeThickness="4"
                                         StrokeDashArray="10 40"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Rakip aranıyor..."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding HostElo, StringFormat='ELO: {0}'}"
                                   FontSize="12"
                                   Foreground="#555555"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"/>
                        <Button Height="36"
                                Padding="20,0"
                                Cursor="Hand"
                                Command="{Binding EslesmeyiIptalCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="Transparent"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <TextBlock Text="İptal" FontSize="12" Foreground="#888888"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ EŞLEŞME BULUNDU (ODA) ═══════════════ -->
                <Border x:Name="OdaPaneli"
                        Background="#141414"
                        BorderBrush="#1A3A1A"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="22,18"
                        Margin="0,0,0,12"
                        Visibility="Collapsed"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="OdaScale" ScaleX="0.92" ScaleY="0.92"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <!-- Badge -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#1E2A1E" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                <TextBlock Text="Eşleşme Bulundu ✓" FontSize="11" Foreground="#00D26A" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <!-- İki oyuncu kartı -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Ben (sol) -->
                            <Border Grid.Column="0"
                                    Background="#1A1A1A"
                                    CornerRadius="12"
                                    Padding="14,12"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                                            Margin="0,0,0,8" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding CardImageSource}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock x:Name="OdaBenAvatarHarf"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#444444"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding OyuncuAdi}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding OyuncuTag, StringFormat='#{0}'}"
                                               FontSize="10"
                                               Foreground="#555555"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image Source="{Binding RankIkonKaynak}"
                                               Width="16" Height="16"
                                               Margin="0,0,4,0"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding HostElo, Mode=OneWay}"
                                                       FontSize="11" Foreground="#888888"/>
                                            <TextBlock Text=" ELO" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- VS -->
                            <Border Grid.Column="1"
                                    Width="36" Height="36"
                                    CornerRadius="18"
                                    Background="#252525"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    Margin="8,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="VS"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Rakip (sağ) -->
                            <Border Grid.Column="2"
                                    Background="#1A1A1A"
                                    CornerRadius="12"
                                    Padding="14,12"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                                            Margin="0,0,0,8" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding RakipCardImageSource}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock x:Name="OdaRakipAvatarHarf"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#444444"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding RakipAdi}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding RakipTag, StringFormat='#{0}'}"
                                               FontSize="10"
                                               Foreground="#555555"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Image Source="{Binding RakipRankIkon}"
                                               Width="16" Height="16"
                                               Margin="0,0,4,0"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding RakipEloText, Mode=OneWay}"
                                                       FontSize="11" Foreground="#888888"/>
                                            <TextBlock Text=" ELO" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Grup Kodu Bölümü -->
                        <Border Background="#1A1A1A" CornerRadius="10" Padding="16,14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Valorant Grup Kodu"
                                           FontSize="11"
                                           Foreground="#666666"
                                           Margin="0,0,0,8"/>

                                <!-- Grup kodu girilmemişse (sadece host girebilir) -->
                                <StackPanel Visibility="{Binding OdaGrupKoduGirildi, Converter={StaticResource InvBoolToVis}}">
                                    <TextBox x:Name="OdaGrupKoduBox"
                                             Style="{StaticResource DarkInput}"
                                             Text="{Binding OdaGrupKoduInput, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="10"
                                             CharacterCasing="Upper"
                                             KeyDown="OdaGrupKoduBox_KeyDown"
                                             IsEnabled="{Binding BenHost}"/>
                                    <TextBlock Text="Sadece siz (host) grup kodunu girebilirsiniz."
                                               FontSize="10"
                                               Foreground="#444444"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding BenHost, Converter={StaticResource InvBoolToVis}}"/>
                                    <Button Height="38"
                                            Margin="0,10,0,0"
                                            Cursor="Hand"
                                            Command="{Binding OdaGrupKoduKaydetCommand}"
                                            Template="{StaticResource DarkBtnTemplate}"
                                            Background="#FFFFFF"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Visibility="{Binding BenHost, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Kodu Paylaş"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#0D0D0D"/>
                                    </Button>
                                </StackPanel>

                                <!-- Grup kodu girilmişse -->
                                <StackPanel Visibility="{Binding OdaGrupKoduGirildi, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding AktifOda.GroupCode}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               FontFamily="Consolas"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4"/>
                                    <Button Height="38"
                                            Margin="0,10,0,0"
                                            Cursor="Hand"
                                            Command="{Binding OdaKoduKopyalaCommand}"
                                            Template="{StaticResource DarkBtnTemplate}"
                                            Background="#1E1E1E"
                                            BorderBrush="#333333"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding KopyalaButonText}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Kapat -->
                        <Button Height="38"
                                Padding="20,0"
                                Cursor="Hand"
                                Command="{Binding EslesmeyiIptalCommand}"
                                Template="{StaticResource DarkBtnTemplate}"
                                Background="Transparent"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <TextBlock Text="Eşleşmeyi Kapat" FontSize="12" Foreground="#888888"/>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ MODAL OVERLAY ═══════════════ -->
        <Grid x:Name="ModalOverlay" Visibility="Collapsed" Background="#88000000">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ModalKapatCommand}"/>
            </Grid.InputBindings>

            <Border x:Name="ModalKutu"
                    Background="#161616"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="28,24"
                    MaxWidth="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    Opacity="0">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ModalScale" ScaleX="0.95" ScaleY="0.95"/>
                </Border.RenderTransform>

                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Lobi Oluştur" FontSize="17" FontWeight="Bold" Foreground="White"/>
                        <Border HorizontalAlignment="Right"
                                Width="26" Height="26"
                                CornerRadius="13"
                                Background="#1E1E1E"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ModalKapatCommand}"/>
                            </Border.InputBindings>
                            <TextBlock Text="&#x2715;"
                                       FontSize="11"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="Valorant grup kodunu gir"
                               FontSize="12"
                               Foreground="#555555"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Grup Kodu" FontSize="11" Foreground="#666666" Margin="0,0,0,6"/>
                    <TextBox x:Name="GrupKoduBox"
                             Style="{StaticResource DarkInput}"
                             Text="{Binding GrupKoduInput, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="10"
                             CharacterCasing="Upper"
                             KeyDown="GrupKoduBox_KeyDown"/>

                    <TextBlock Text="{Binding ModalHata}"
                               FontSize="11"
                               Foreground="#FF4655"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding ModalHata, Converter={StaticResource StrToVis}}"/>

                    <Button Height="46"
                            Margin="0,18,0,0"
                            Cursor="Hand"
                            Command="{Binding LobiOlusturOnayCommand}"
                            Template="{StaticResource DarkBtnTemplate}"
                            Background="#FFFFFF"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <Button.IsEnabled>
                            <Binding Path="ModalLoading">
                                <Binding.Converter>
                                    <h:InverseBoolConverter/>
                                </Binding.Converter>
                            </Binding>
                        </Button.IsEnabled>
                        <TextBlock FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#0D0D0D"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Lobi Oluştur"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModalLoading}" Value="True">
                                            <Setter Property="Text" Value="Oluşturuluyor..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Yakinda overlay (visibility collapsed for v3.9.2+) -->
        <Border Background="#0D0D0D" IsHitTestVisible="False" Visibility="Collapsed"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x1F527;" FontSize="40" Foreground="#555555" HorizontalAlignment="Center"/>
                <TextBlock Text="Yakinda" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                <TextBlock Text="Bu ozellik cok yakinda eklenecek" FontSize="13"
                           Foreground="#555555" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
